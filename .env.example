# Database Connection for Vercel/Serverless
# IMPORTANT: You need TWO environment variables in Vercel:

# 1. DATABASE_URL - For connection pooling (used by application at runtime)
DATABASE_URL="mysql://u366636586_dhruvilchitrod:Mahadev@6163@srv914.hstgr.io:3306/u366636586_anigrativ_loan?connection_limit=5&connect_timeout=30&pool_timeout=30"

# 2. DIRECT_DATABASE_URL - For direct connections (used by Prisma CLI for migrations)
DIRECT_DATABASE_URL="mysql://u366636586_dhruvilchitrod:Mahadev@6163@srv914.hstgr.io:3306/u366636586_anigrativ_loan"

# NextAuth Secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Firebase Configuration (if using Firebase)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
