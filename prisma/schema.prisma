model UserPreference {
  id                   String   @id
  userId               String   @unique
  theme                String   @default("SYSTEM")
  primaryColor         String   @default("emerald")
  autoLogoutMinutes    Int      @default(15)
  showLogoutWarning    Boolean  @default(true)
  logoutWarningMinutes Int      @default(2)
  enableNotifications  Boolean  @default(true)
  enableSoundAlerts    Boolean  @default(true)
  language             String   @default("en")
  createdAt            DateTime @default(now())
  updatedAt            DateTime
  User                 User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model UserSession {
  id             String    @id
  userId         String
  sessionToken   String    @unique
  deviceInfo     String?
  ipAddress      String?
  location       String?
  userAgent      String?
  lastActivityAt DateTime  @default(now())
  loginAt        DateTime  @default(now())
  logoutAt       DateTime?
  isActive       Boolean   @default(true)
  logoutReason   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
  User           User      @relation(fields: [userId], references: [id])

  @@index([lastActivityAt])
  @@index([isActive])
  @@index([sessionToken])
  @@index([userId])
}

model ValidationFixLog {
  id              String          @id
  issueId         String
  fixType         String
  fixApplied      String
  appliedById     String?
  appliedByName   String?
  result          String
  errorMessage    String?
  affectedRecords Int             @default(0)
  beforeState     String?
  afterState      String?
  startedAt       DateTime        @default(now())
  completedAt     DateTime?
  durationMs      Int?
  createdAt       DateTime        @default(now())
  ValidationIssue ValidationIssue @relation(fields: [issueId], references: [id])

  @@index([createdAt])
  @@index([result])
  @@index([issueId])
}

model ValidationIssue {
  id                 String             @id
  ruleId             String
  entityType         String
  entityId           String
  entityIdentifier   String?
  title              String
  description        String
  severity           String
  currentState       String
  expectedState      String
  differenceAnalysis String?
  suggestedFix       String
  fixDescription     String
  fixSqlPreview      String?
  relatedEntities    String?
  status             String             @default("PENDING")
  reviewedById       String?
  reviewedByName     String?
  reviewedAt         DateTime?
  reviewNotes        String?
  fixedById          String?
  fixedByName        String?
  fixedAt            DateTime?
  fixResult          String?
  snoozedUntil       DateTime?
  snoozedById        String?
  snoozeReason       String?
  recurrenceCount    Int                @default(0)
  parentIssueId      String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime
  ValidationFixLog   ValidationFixLog[]
  ValidationRule     ValidationRule     @relation(fields: [ruleId], references: [id])

  @@index([ruleId])
  @@index([createdAt])
  @@index([severity])
  @@index([entityType, entityId])
  @@index([status])
}

model ValidationRule {
  id                String            @id
  code              String            @unique
  name              String
  description       String
  category          String
  severity          String            @default("MEDIUM")
  isActive          Boolean           @default(true)
  autoFixable       Boolean           @default(false)
  requiresApproval  Boolean           @default(true)
  detectionLogic    String
  fixLogic          String?
  impactDescription String?
  fixGuidance       String?
  timesDetected     Int               @default(0)
  timesFixed        Int               @default(0)
  lastDetectedAt    DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  ValidationIssue   ValidationIssue[]

  @@index([severity])
  @@index([isActive])
  @@index([category])
}

model ValidatorRun {
  id               String    @id
  runType          String
  triggeredBy      String?
  triggeredByName  String?
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  durationMs       Int?
  status           String    @default("RUNNING")
  rulesRun         Int       @default(0)
  recordsScanned   Int       @default(0)
  issuesFound      Int       @default(0)
  issuesByCategory String?
  issuesBySeverity String?
  errorMessage     String?
  errorStack       String?
  peakMemoryMb     Float?
  avgRuleTimeMs    Float?
  createdAt        DateTime  @default(now())

  @@index([runType])
  @@index([startedAt])
  @@index([status])
}

model ValidatorSettings {
  id                      String    @id @unique
  isEnabled               Boolean   @default(true)
  scheduleType            String    @default("HOURLY")
  customCron              String?
  lastRunAt               DateTime?
  nextRunAt               DateTime?
  isRunning               Boolean   @default(false)
  maxIssuesPerRun         Int       @default(100)
  timeoutMinutes          Int       @default(30)
  notifyOnIssues          Boolean   @default(true)
  notifyOnCritical        Boolean   @default(true)
  notifyOnFixes           Boolean   @default(true)
  notifyEmails            String?
  autoFixEnabled          Boolean   @default(false)
  autoFixSeverities       String?
  autoFixRequiresApproval Boolean   @default(true)
  disabledRules           String?
  parallelRules           Boolean   @default(false)
  batchSize               Int       @default(50)
  totalRuns               Int       @default(0)
  totalIssuesFound        Int       @default(0)
  totalIssuesFixed        Int       @default(0)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime
}

model VehicleLoanDetail {
  id                String           @id
  loanApplicationId String?          @unique
  offlineLoanId     String?          @unique
  vehicleType       String
  vehicleNumber     String?
  manufacturer      String?
  model             String?
  yearOfManufacture Int?
  valuationAmount   Float
  loanAmount        Float
  ownerName         String?
  rcBookPhoto       String?
  vehiclePhoto      String?
  chassisNumber     String?
  engineNumber      String?
  fuelType          String?
  color             String?
  verificationDate  DateTime?
  verifiedBy        String?
  remarks           String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime
  OfflineLoan       OfflineLoan?     @relation(fields: [offlineLoanId], references: [id])
  LoanApplication   LoanApplication? @relation(fields: [loanApplicationId], references: [id])

  @@index([vehicleNumber])
  @@index([offlineLoanId])
  @@index([loanApplicationId])
}

model WorkflowLog {
  id                String          @id
  loanApplicationId String
  actionById        String
  previousStatus    String?
  newStatus         String
  action            String
  remarks           String?
  ipAddress         String?
  userAgent         String?
  location          String?
  signatureHash     String?
  createdAt         DateTime        @default(now())
  LoanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])
  User              User            @relation(fields: [actionById], references: [id])

  @@index([actionById])
  @@index([loanApplicationId])
}

model receipt_templates {
  id          String   @id
  type        String   @unique
  name        String
  companyName String   @default("MoneyMitra Finance")
  bgColor     String   @default("#ffffff")
  accentColor String   @default("#4F46E5")
  fields      String
  createdById String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model system_settings {
  id                        String   @id
  penaltyPerDay             Float    @default(100)
  penaltyGraceDays          Int      @default(0)
  penaltyMaxAmount          Float?
  colorGreenDays            Int      @default(2)
  colorYellowDays           Int      @default(1)
  colorRedDaysOverdue       Int      @default(0)
  agentCanSeeMirror         Boolean  @default(false)
  staffCanSeeMirror         Boolean  @default(false)
  companyCanSeeMirror       Boolean  @default(false)
  accountantCanSeeMirror    Boolean  @default(false)
  sendEMIReminderDaysBefore Int      @default(3)
  sendEMISameDayReminder    Boolean  @default(true)
  sendPenaltyNotify         Boolean  @default(true)
  penaltyNotifyIntervalHrs  Int      @default(24)
  onlineProcessingFeeMode   String   @default("AT_DISBURSEMENT")
  offlineProcessingFeeMode  String   @default("AT_CREATION")
  notificationScenarios     String?
  themeColor                String   @default("#4F46E5")
  updatedById               String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime
}
