generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "mysql"
  url       = env("DATABASE_URL")
  directUrl  = env("DATABASE_URL")
}

model User {
  id                           String                 @id @default(cuid())
  firebaseUid                  String                 @unique
  email                        String                 @unique
  phone                        String?
  name                         String?
  role                         UserRole               @default(CUSTOMER)
  isActive                     Boolean                @default(true)
  isLocked                     Boolean                @default(false)
  failedLoginAttempts          Int                    @default(0)
  lastLoginAt                  DateTime?
  profilePicture               String?
  companyId                    String?
  agentId                      String?
  agentCode                    String?                @unique
  commissionRate               Float?                 @default(0)
  staffCode                    String?                @unique
  assignedBranch               String?
  cashierCode                  String?                @unique
  accountantCode               String?                @unique
  dailyLimit                   Float?                 @default(100000)
  panNumber                    String?
  aadhaarNumber                String?
  dateOfBirth                  DateTime?
  address                      String?
  city                         String?
  state                        String?
  pincode                      String?
  employmentType               String?
  monthlyIncome                Float?
  bankAccountNumber            String?
  bankIfsc                     String?
  bankName                     String?
  termsAccepted                Boolean                @default(false)
  termsAcceptedAt              DateTime?
  termsAcceptedIp              String?
  privacyAccepted              Boolean                @default(false)
  privacyAcceptedAt            DateTime?
  privacyAcceptedIp            String?
  password                     String?
  verificationCode             String?
  verificationCodeExpiry       DateTime?
  staffVerificationCode        String?
  showPassword                 Boolean                @default(false)
  plainPassword                String?
  loginType                    String                 @default("EMAIL")
  lastActivityAt               DateTime?
  lastLocation                 String?
  // Push Notification Fields
  fcmToken                     String?                // Firebase Cloud Messaging token for push notifications
  notificationEnabled          Boolean                @default(true) // User preference for push notifications
  // Credit System Fields - Dual Credit System
  companyCredit                Float                  @default(0) // Company credit - only CASH payments increase this
  personalCredit               Float                  @default(0) // Personal credit - when money taken in personal account
  // Legacy field for backward compatibility
  credit                       Float                  @default(0) // Total credit (companyCredit + personalCredit)
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  deletedAt                    DateTime?
  auditLogs                    AuditLog[]
  blacklists                   Blacklist[]
  deviceFingerprints           DeviceFingerprint[]
  disbursedLoans               LoanApplication[]      @relation("DisbursedBy")
  rejectedLoans                LoanApplication[]      @relation("RejectedBy")
  processedLoans               LoanApplication[]      @relation("ProcessedLoans")
  loanApplications             LoanApplication[]      @relation("CustomerApplications")
  locationLogs                 LocationLog[]
  notifications                Notification[]
  cashierPayments              Payment[]              @relation("CashierPayments")
  payments                     Payment[]              @relation("CustomerPayments")
  reminders                    Reminder[]
  sessions                     SessionForm[]
  notificationSettings         NotificationSetting[]
  agent                        User?                  @relation("AgentStaff", fields: [agentId], references: [id])
  staffMembers                 User[]                 @relation("AgentStaff")
  company                      Company?               @relation(fields: [companyId], references: [id])
  workflowLogs                 WorkflowLog[]
  // Credit System Relations
  creditTransactions           CreditTransaction[]    @relation("UserCreditTransactions")
  creditSettlements            CashierSettlement[]    @relation("UserSettlements")
  receivedSettlements          CashierSettlement[]    @relation("CashierReceivedSettlements")
  // Advanced features relations
  preApprovedOffers            PreApprovedOffer[]
  creditRiskScores             CreditRiskScore[]
  referrals                    Referral[]
  agentPerformance             AgentPerformance[]
  // Offline Loan relations
  createdOfflineLoans          OfflineLoan[]          @relation("OfflineLoanCreator")
  offlineLoansAsCustomer       OfflineLoan[]          @relation("OfflineLoanCustomer")
  collectedEMIs                OfflineLoanEMI[]
  emiReminders                 EMIReminderLog[]
  // Action Log relations
  actionLogs                   ActionLog[]
  undoneActions                ActionLog[]            @relation("ActionUndoBy")
  redoneActions                ActionLog[]            @relation("ActionRedoBy")
  // Interest Only Loan relations
  startedEmiPhaseLoans         InterestOnlyLoan[]
  // Payment Request relations
  paymentRequests              PaymentRequest[]
  reviewedPaymentRequests      PaymentRequest[]       @relation("PaymentRequestReviewer")
  // Secondary Payment Pages (created by this user)
  createdSecondaryPaymentPages SecondaryPaymentPage[]
  // Secondary Payment Pages (where this user is the role)
  roleSecondaryPaymentPages    SecondaryPaymentPage[] @relation("PaymentPageRole")
  // Company Payment Pages where this user receives secondary payments
  secondaryPaymentPagesForRole CompanyPaymentPage[]   @relation("SecondaryPaymentRole")
  // EMI Payment Settings modifications
  modifiedEMIPaymentSettings   EMIPaymentSetting[]
  // Ticket System Relations
  customerTickets              SupportTicket[]        @relation("CustomerTickets")
  assignedTickets              SupportTicket[]        @relation("AssignedTickets")
  // Chat Relations
  chatbotSessions              ChatbotSession[]
  customerLiveChats            LiveChatSession[]      @relation("CustomerLiveChats")
  adminLiveChats               LiveChatSession[]      @relation("AdminLiveChats")
  liveChatMessages             LiveChatMessage[]      @relation("LiveChatSender")
  // Session & Preferences
  userSessions                 UserSession[]
  userPreference               UserPreference?
  // Messaging System
  messagesSent                 Message[]              @relation("MessagesSent")
  messagesReceived             Message[]              @relation("MessagesReceived")

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([agentId])
}

model Company {
  id                           String                  @id @default(cuid())
  name                         String
  code                         String                  @unique
  registrationNo               String?
  gstNumber                    String?
  panNumber                    String? // Company PAN Number
  address                      String?
  city                         String?
  state                        String?
  pincode                      String?
  country                      String?                 @default("India")
  contactEmail                 String?
  contactPhone                 String?
  website                      String? // Company website
  // Owner/Director Details
  ownerName                    String? // Owner/Director name
  ownerPhone                   String? // Owner phone
  ownerEmail                   String? // Owner email
  ownerAadhaar                 String? // Owner Aadhaar (encrypted)
  ownerPan                     String? // Owner PAN
  // Logo
  logoUrl                      String? // Company logo URL (uploaded file)
  isActive                     Boolean                 @default(true)
  maxLoanAmount                Float                   @default(10000000)
  minLoanAmount                Float                   @default(10000)
  defaultInterestRate          Float                   @default(12)
  maxTenureMonths              Int                     @default(60)
  // Company Credit - only CASH payments increase this
  companyCredit                Float                   @default(0)
  // My Cash - For Company 3 (cash only company)
  myCash                       Float                   @default(0)
  // Interest Type Settings
  defaultInterestType          String                  @default("FLAT") // FLAT or REDUCING
  // Mirror Loan Settings
  enableMirrorLoan             Boolean                 @default(false)
  mirrorInterestRate           Float? // DEPRECATED - Interest rate now set per loan
  mirrorInterestType           String? // DEPRECATED - Interest type now set per loan (FLAT or REDUCING)
  // Company Type - Mirror Company (Company 1 & 2) vs Original Company (Company 3)
  // Mirror companies have bank accounts, Original company only has cash book
  // Interest rate for mirror loans is set PER LOAN, not per company
  isMirrorCompany              Boolean                 @default(true) // true = Company 1/2, false = Company 3
  // Accounting Type - FULL (Chart of Accounts, Trial Balance, etc.) or CASHBOOK_ONLY (Cashbook & Daybook)
  accountingType               String                  @default("FULL") // FULL or CASHBOOK_ONLY
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt
  deletedAt                    DateTime?
  // Relations
  ledgers                      Ledger[]
  loanApplications             LoanApplication[]
  users                        User[]
  // Accounting Relations
  chartOfAccounts              ChartOfAccount[]
  financialYears               FinancialYear[]
  journalEntries               JournalEntry[]
  expenses                     Expense[]
  bankAccounts                 BankAccount[]
  gstConfigs                   GSTConfig[]
  // Advanced features relations
  preApprovedOffers            PreApprovedOffer[]
  commissionSlabs              CommissionSlab[]
  gracePeriodConfigs           GracePeriodConfig[]
  agentPerformance             AgentPerformance[]
  // Offline Loan relations
  offlineLoans                 OfflineLoan[]
  // Fixed Assets relations
  fixedAssets                  FixedAsset[]
  // Payment Settings
  paymentSettings              CompanyPaymentSettings?
  // Default Payment Page
  defaultPaymentPage           CompanyPaymentPage?
  // Secondary Payment Pages (for display only)
  secondaryPaymentPages        SecondaryPaymentPage[]
  // Mirror Loan Relations
  mirrorLoanMappings           MirrorLoanMapping[]
  // Mirror Loan as Original Company (Company 3)
  originalLoanMappings         MirrorLoanMapping[]     @relation("OriginalCompany")
  // Pending Mirror Loan Relations
  pendingMirrorLoansAsMirror   PendingMirrorLoan[]
  pendingMirrorLoansAsOriginal PendingMirrorLoan[]     @relation("PendingMirrorOriginalCompany")
  // Cash Book - For Company 3 (no bank account, uses cash only)
  cashBook                     CashBook?

  @@index([code])
}

// Global Loan Sequence - Tracks sequential loan numbers across all companies and loan types
model LoanSequence {
  id              String   @id @default(cuid())
  currentSequence Int      @default(0) // Current sequence number
  lastUpdatedAt   DateTime @updatedAt
}

model LoanApplication {
  id                        String                   @id @default(cuid())
  applicationNo             String                   @unique
  customerId                String
  companyId                 String?
  loanType                  LoanType                 @default(PERSONAL)
  status                    LoanStatus               @default(SUBMITTED)
  requestedAmount           Float
  requestedTenure           Int
  requestedInterestRate     Float?
  purpose                   String?
  title                     String?
  firstName                 String?
  middleName                String?
  lastName                  String?
  fatherName                String?
  motherName                String?
  gender                    String?
  maritalStatus             String?
  panNumber                 String?
  aadhaarNumber             String?
  dateOfBirth               DateTime?
  nationality               String?
  address                   String?
  city                      String?
  state                     String?
  pincode                   String?
  phone                     String?
  employmentType            String?
  employerName              String?
  employerAddress           String?
  designation               String?
  yearsInEmployment         Int?
  totalWorkExperience       Int?
  officePhone               String?
  officeEmail               String?
  monthlyIncome             Float?
  annualIncome              Float?
  otherIncome               Float?
  incomeSource              String?
  // Employment-specific fields
  businessName              String?
  businessType              String?
  yearsInBusiness           Int?
  annualTurnover            Float?
  businessAddress           String?
  companyType               String?
  yearsInOperation          Int?
  annualRevenue             Float?
  numberOfEmployees         Int?
  professionType            String?
  practiceName              String?
  yearsOfPractice           Int?
  professionalRegNo         String?
  previousEmployer          String?
  retirementDate            DateTime?
  pensionAmount             Float?
  spouseName                String?
  spouseOccupation          String?
  spouseIncome              Float?
  familyIncome              Float?
  institutionName           String?
  courseProgram             String?
  expectedCompletion        DateTime?
  guardianName              String?
  guardianIncome            Float?
  sourceOfFunds             String?
  monthlySupportAmount      Float?
  supportProviderName       String?
  // Bank Details
  bankAccountNumber         String?
  bankIfsc                  String?
  bankName                  String?
  bankBranch                String?
  accountType               String?
  accountHolderName         String?
  loanAmount                Float?
  tenure                    Int?
  interestRate              Float?
  emiAmount                 Float?
  processingFee             Float?
  panCardDoc                String?   @db.LongText
  aadhaarFrontDoc           String?   @db.LongText
  aadhaarBackDoc            String?   @db.LongText
  incomeProofDoc            String?   @db.LongText
  addressProofDoc           String?   @db.LongText
  photoDoc                  String?   @db.LongText
  bankStatementDoc          String?   @db.LongText
  passbookDoc               String?   @db.LongText
  salarySlipDoc             String?   @db.LongText
  electionCardDoc           String?   @db.LongText
  housePhotoDoc             String?   @db.LongText
  otherDocs                 String?   @db.LongText
  reference1Name            String?
  reference1Phone           String?
  reference1Relation        String?
  reference1Address         String?
  reference2Name            String?
  reference2Phone           String?
  reference2Relation        String?
  reference2Address         String?
  digitalSignature          String?   @db.LongText
  signatureHash             String?
  consentGiven              Boolean                  @default(false)
  consentTimestamp          DateTime?
  consentIp                 String?
  applicationLocation       String?
  currentHandlerId          String?
  currentStage              String?
  riskScore                 Int?                     @default(0)
  fraudFlag                 Boolean                  @default(false)
  fraudReason               String?
  rejectionReason           String?
  rejectedById              String?
  rejectedAt                DateTime?
  disbursedAmount           Float?
  disbursedAt               DateTime?
  disbursedById             String?
  disbursementMode          String?
  disbursementRef           String?
  disbursementProof         String?   @db.LongText
  submittedAt               DateTime                 @default(now())
  saApprovedAt              DateTime?
  companyApprovedAt         DateTime?
  agentApprovedAt           DateTime?
  loanFormCompletedAt       DateTime?
  sessionCreatedAt          DateTime?
  customerApprovedAt        DateTime?
  finalApprovedAt           DateTime?
  closedAt                  DateTime?
  // Interest-Only Loan Fields
  isInterestOnlyLoan        Boolean                  @default(false) // True if this is an interest-only loan
  interestOnlyStartDate     DateTime? // When interest-only phase started
  interestOnlyMonthlyAmount Float? // Monthly interest amount to collect during interest-only phase
  loanStartedAt             DateTime? // When loan was converted from interest-only to normal
  totalInterestOnlyPaid     Float                    @default(0) // Total interest collected during interest-only phase
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  deletedAt                 DateTime?
  auditLogs                 AuditLog[]
  emiSchedules              EMISchedule[]
  disbursedBy               User?                    @relation("DisbursedBy", fields: [disbursedById], references: [id])
  rejectedBy                User?                    @relation("RejectedBy", fields: [rejectedById], references: [id])
  processedBy               User?                    @relation("ProcessedLoans", fields: [currentHandlerId], references: [id])
  company                   Company?                 @relation(fields: [companyId], references: [id])
  customer                  User                     @relation("CustomerApplications", fields: [customerId], references: [id])
  loanForm                  LoanForm?
  payments                  Payment[]
  sessionForm               SessionForm?
  workflowLogs              WorkflowLog[]
  // Advanced features relations
  loanTopUps                LoanTopUp[]
  foreclosureRequests       ForeclosureRequest[]
  emiDateChangeRequests     EMIDateChangeRequest[]
  counterOffers             CounterOffer[]
  documentRequests          DocumentRequest[]
  loanRestructures          LoanRestructure[]
  npaTrackings              NPATracking[]
  fraudAlerts               FraudAlert[]
  appointments              Appointment[]
  loanAgreement             LoanAgreement?
  progressTimelines         LoanProgressTimeline[]
  applicationFingerprints   ApplicationFingerprint[]
  // Payment Request relations
  paymentRequests           PaymentRequest[]
  // EMI Payment Settings
  emiPaymentSettings        EMIPaymentSetting[]
  // Interest Only Loan
  interestOnlyLoan          InterestOnlyLoan?
  // Loan Type Specific Details
  goldLoanDetail            GoldLoanDetail?
  vehicleLoanDetail         VehicleLoanDetail?

  // Mirror Loan Relations - Note: MirrorLoanMapping now supports both online and offline loans
  // Relations removed to support offline loan IDs without foreign key constraints
  // Pending Mirror Loan Relations - Also removed for same reason
  @@index([applicationNo])
  @@index([customerId])
  @@index([status])
  @@index([companyId])
  @@index([status, companyId]) // compound: dashboard filtered by company + status
  @@index([customerId, status]) // compound: customer loan list filtered by status
}

model LoanForm {
  id                  String          @id @default(cuid())
  loanApplicationId   String          @unique
  panVerified         Boolean         @default(false)
  aadhaarVerified     Boolean         @default(false)
  bankVerified        Boolean         @default(false)
  employmentVerified  Boolean         @default(false)
  addressVerified     Boolean         @default(false)
  incomeVerified      Boolean         @default(false)
  verificationRemarks String?
  verificationDate    DateTime?
  verifiedById        String?
  riskScore           Int             @default(0)
  riskFactors         String?
  fraudFlag           Boolean         @default(false)
  fraudReason         String?
  internalRemarks     String?
  visitDate           DateTime?
  visitAddress        String?
  visitRemarks        String?
  visitLatitude       Float?
  visitLongitude      Float?
  visitPhotos         String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?
  loanApplication     LoanApplication @relation(fields: [loanApplicationId], references: [id])

  @@index([loanApplicationId])
}

model SessionForm {
  id                    String          @id @default(cuid())
  loanApplicationId     String          @unique
  agentId               String
  approvedAmount        Float
  interestRate          Float
  interestType          String          @default("FLAT") // FLAT or REDUCING
  tenure                Int
  emiFrequency          String          @default("MONTHLY")
  processingFee         Float           @default(0)
  processingFeeType     String          @default("PERCENTAGE")
  emiAmount             Float
  totalInterest         Float
  totalAmount           Float
  moratoriumPeriod      Int             @default(0)
  moratoriumType        String?
  latePaymentPenalty    Float           @default(0)
  bounceCharges         Float           @default(0)
  specialConditions     String?
  requestedAmount       Float?
  requestedTenure       Int?
  requestedInterestRate Float?
  customerApproved      Boolean         @default(false)
  customerApprovedAt    DateTime?
  customerSignature     String?   @db.LongText
  customerSignatureHash String?
  rejected              Boolean         @default(false)
  rejectedAt            DateTime?
  rejectionReason       String?
  isLocked              Boolean         @default(false)
  lockedAt              DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  deletedAt             DateTime?
  agent                 User            @relation(fields: [agentId], references: [id])
  loanApplication       LoanApplication @relation(fields: [loanApplicationId], references: [id])

  @@index([loanApplicationId])
  @@index([agentId])
}

// Gold Loan Details - Specific fields for Gold Loan applications
model GoldLoanDetail {
  id                String           @id @default(cuid())
  loanApplicationId String?          @unique // For online loans
  offlineLoanId     String?          @unique // For offline loans
  grossWeight       Float // Gross weight in grams
  netWeight         Float // Net weight in grams  
  goldRate          Float // Gold rate per gram
  valuationAmount   Float // Total valuation amount
  loanAmount        Float // Approved loan amount
  ownerName         String? // Name of gold owner
  goldItemPhoto     String? // Photo URL of gold item
  karat             Int? // Gold purity (22K, 24K, etc.)
  numberOfItems     Int? // Number of gold items
  itemDescription   String? // Description of gold items
  verificationDate  DateTime? // Date of verification
  verifiedBy        String? // Staff who verified
  remarks           String? // Additional remarks
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  loanApplication   LoanApplication? @relation(fields: [loanApplicationId], references: [id])
  offlineLoan       OfflineLoan?     @relation(fields: [offlineLoanId], references: [id])

  @@index([loanApplicationId])
  @@index([offlineLoanId])
}

// Vehicle Loan Details - Specific fields for Vehicle Loan applications  
model VehicleLoanDetail {
  id                String           @id @default(cuid())
  loanApplicationId String?          @unique // For online loans
  offlineLoanId     String?          @unique // For offline loans
  vehicleType       String // Type: Car, Bike, Truck, etc.
  vehicleNumber     String? // Vehicle registration number
  manufacturer      String? // Vehicle manufacturer
  model             String? // Vehicle model
  yearOfManufacture Int? // Year of manufacture
  valuationAmount   Float // Vehicle valuation amount
  loanAmount        Float // Approved loan amount
  ownerName         String? // Name of vehicle owner
  rcBookPhoto       String? // RC Book photo URL
  vehiclePhoto      String? // Vehicle photo URL
  chassisNumber     String? // Chassis number
  engineNumber      String? // Engine number
  fuelType          String? // Petrol, Diesel, Electric, etc.
  color             String? // Vehicle color
  verificationDate  DateTime? // Date of verification
  verifiedBy        String? // Staff who verified
  remarks           String? // Additional remarks
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  loanApplication   LoanApplication? @relation(fields: [loanApplicationId], references: [id])
  offlineLoan       OfflineLoan?     @relation(fields: [offlineLoanId], references: [id])

  @@index([loanApplicationId])
  @@index([offlineLoanId])
  @@index([vehicleNumber])
}

model EMISchedule {
  id                   String             @id @default(cuid())
  loanApplicationId    String
  installmentNumber    Int
  dueDate              DateTime
  originalDueDate      DateTime
  principalAmount      Float
  interestAmount       Float
  totalAmount          Float
  outstandingPrincipal Float
  outstandingInterest  Float
  paidAmount           Float              @default(0)
  paidPrincipal        Float              @default(0)
  paidInterest         Float              @default(0)
  paymentStatus        EMIPaymentStatus   @default(PENDING)
  paidDate             DateTime?
  paymentMode          String?
  paymentReference     String?
  utrNumber            String?
  proofUrl             String? // Payment proof document URL
  notes                String? // Payment notes
  isPartialPayment     Boolean            @default(false)
  nextPaymentDate      DateTime?
  isInterestOnly       Boolean            @default(false)
  principalDeferred    Boolean            @default(false)
  penaltyAmount        Float              @default(0)
  penaltyPaid          Float              @default(0)
  waivedAmount         Float              @default(0)
  waiverReason         String?
  waivedById           String?
  waivedAt             DateTime?
  daysOverdue          Int                @default(0)
  overdueNoticeSent    Boolean            @default(false)
  lastNoticeDate       DateTime?
  // Partial Payment Tracking
  partialPaymentCount  Int                @default(0) // Number of partial payments made (max 2)
  remainingAmount      Float              @default(0) // Amount remaining after partial payment
  newDueDate           DateTime? // New due date after partial payment
  // Interest Only Payment Tracking
  interestOnlyPaidAt   DateTime? // When interest only was paid
  interestOnlyAmount   Float              @default(0) // Interest amount paid
  duplicatedEMINumber  Int? // If this EMI was duplicated due to interest only payment
  originalEMIId        String? // Reference to original EMI if this is a duplicate
  // Payment History JSON - stores array of payment records
  paymentHistoryJson   String?  @db.LongText // JSON array of {amount, principal, interest, penalty, mode, reference, paidAt, collectedBy}
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  loanApplication      LoanApplication    @relation(fields: [loanApplicationId], references: [id])
  payments             Payment[]
  paymentRequests      PaymentRequest[]
  paymentSetting       EMIPaymentSetting?

  @@unique([loanApplicationId, installmentNumber])
  @@index([loanApplicationId])
  @@index([dueDate])
  @@index([paymentStatus])
}

model Payment {
  id                 String          @id @default(cuid())
  loanApplicationId  String
  emiScheduleId      String?
  customerId         String
  cashierId          String?
  paidById           String? // Who made the payment (staff/cashier/agent)
  paymentType        PaymentType     @default(FULL_EMI)
  amount             Float
  principalComponent Float           @default(0)
  interestComponent  Float           @default(0)
  penaltyComponent   Float           @default(0)
  transactionId      String?         @unique
  utrNumber          String?
  paymentMode        String?
  paymentGateway     String?
  gatewayResponse    String?
  status             PaymentStatus   @default(PENDING)
  verified           Boolean         @default(false)
  verifiedById       String?
  verifiedAt         DateTime?
  receiptNumber      String?         @unique
  receiptGenerated   Boolean         @default(false)
  receiptSentAt      DateTime?
  paymentLocation    String?
  deviceInfo         String?
  reconciled         Boolean         @default(false)
  reconciledAt       DateTime?
  reconciliationRef  String?
  proofUrl           String? // Payment proof document
  remarks            String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?
  auditLogs          AuditLog[]
  cashier            User?           @relation("CashierPayments", fields: [cashierId], references: [id])
  customer           User            @relation("CustomerPayments", fields: [customerId], references: [id])
  emiSchedule        EMISchedule?    @relation(fields: [emiScheduleId], references: [id])
  loanApplication    LoanApplication @relation(fields: [loanApplicationId], references: [id])

  @@index([loanApplicationId])
  @@index([customerId])
  @@index([status])
  @@index([transactionId])
}

model WorkflowLog {
  id                String          @id @default(cuid())
  loanApplicationId String
  actionById        String
  previousStatus    String?
  newStatus         String
  action            String
  remarks           String?
  ipAddress         String?
  userAgent         String?
  location          String?
  signatureHash     String?
  createdAt         DateTime        @default(now())
  actionBy          User            @relation(fields: [actionById], references: [id])
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])

  @@index([loanApplicationId])
  @@index([actionById])
}

model AuditLog {
  id                String           @id @default(cuid())
  userId            String
  loanApplicationId String?
  paymentId         String?
  action            String
  module            String
  description       String
  oldValue          String?
  newValue          String?
  ipAddress         String?
  userAgent         String?
  location          String?
  recordId          String?
  recordType        String?
  createdAt         DateTime         @default(now())
  payment           Payment?         @relation(fields: [paymentId], references: [id])
  loanApplication   LoanApplication? @relation(fields: [loanApplicationId], references: [id])
  user              User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([createdAt])
}

model LocationLog {
  id                String   @id @default(cuid())
  userId            String
  latitude          Float
  longitude         Float
  accuracy          Float?
  action            String
  loanApplicationId String?
  paymentId         String?
  deviceId          String?
  deviceType        String?
  browser           String?
  os                String?
  ipAddress         String?
  address           String?
  city              String?
  state             String?
  country           String?
  pincode           String?
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

model NotificationSetting {
  id                        String   @id @default(cuid())
  userId                    String
  enableEMIReminders        Boolean  @default(true)
  reminderDaysBeforeDue     Int      @default(3)
  enableOverdueAlerts       Boolean  @default(true)
  enablePaymentConfirmation Boolean  @default(true)
  enableLoanStatusUpdates   Boolean  @default(true)
  preferredChannel          String   @default("IN_APP")
  reminderTime              String   @default("09:00")
  enableSMS                 Boolean  @default(false)
  enableEmail               Boolean  @default(false)
  enablePush                Boolean  @default(true)
  customReminderMessage     String?
  overdueReminderMessage    String?
  // Penalty waiver reduction notifications
  enablePenaltyWaiverAlerts Boolean  @default(true)
  // Role-specific notification triggers
  enableLoanPassNotify      Boolean  @default(true) // Notify when loan is passed to/from role
  enableMirrorLoanAccess    Boolean  @default(false) // Can this role see mirror loans
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  user                      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// Notification Template - Pre-defined templates for automated notifications
model NotificationTemplate {
  id            String         @id @default(cuid())
  code          String         @unique // Unique code like 'EMI_DUE_TOMORROW', 'LOAN_APPROVED'
  name          String // Display name
  category      String // EMI, LOAN, PAYMENT, SYSTEM, CREDIT
  title         String // Template title with variables like {{customer_name}}
  message       String // Template message with variables
  variables     String? // JSON array of available variables
  isActive      Boolean        @default(true)
  isSystem      Boolean        @default(false) // System templates cannot be deleted
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  notifications Notification[]

  @@index([code])
  @@index([category])
  @@index([isActive])
}

// Notification - Individual notifications sent to users
model Notification {
  id         String                @id @default(cuid())
  userId     String
  templateId String? // Reference to template if used
  type       String // EMI_REMINDER, LOAN_STATUS, PAYMENT, SYSTEM, CREDIT
  category   String                @default("SYSTEM") // EMI, LOAN, PAYMENT, SYSTEM, CREDIT
  priority   String                @default("NORMAL") // LOW, NORMAL, HIGH, CRITICAL
  title      String
  message    String
  data       String? // JSON additional data (loanId, paymentId, etc.)
  isRead     Boolean               @default(false)
  readAt     DateTime?
  actionUrl  String? // URL to navigate when clicked
  actionText String? // Text for action button
  createdAt  DateTime              @default(now())
  user       User                  @relation(fields: [userId], references: [id])
  template   NotificationTemplate? @relation(fields: [templateId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([category])
  @@index([createdAt])
}

model Reminder {
  id          String    @id @default(cuid())
  userId      String
  type        String
  title       String
  message     String
  scheduledAt DateTime
  sentAt      DateTime?
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([scheduledAt])
}

model Blacklist {
  id            String   @id @default(cuid())
  userId        String
  reason        String
  blacklistedAt DateTime @default(now())
  blacklistedBy String?
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model DeviceFingerprint {
  id         String   @id @default(cuid())
  userId     String
  deviceId   String
  deviceName String?
  lastUsed   DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([deviceId])
}

model Ledger {
  id          String   @id @default(cuid())
  companyId   String
  type        String
  amount      Float
  description String?
  reference   String?
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CMSService {
  id                        String        @id @default(cuid())
  title                     String
  description               String
  icon                      String?
  code                      String        @unique @default("LN") // Unique code prefix: GL, VL, PL, BL, HL, etc.
  loanType                  String        @default("PERSONAL")
  isInterestOnly            Boolean       @default(false) // Is this an Interest Only loan product?
  minInterestRate           Float         @default(8)
  maxInterestRate           Float         @default(24)
  defaultInterestRate       Float         @default(12)
  minTenure                 Int           @default(6)
  maxTenure                 Int           @default(60)
  defaultTenure             Int           @default(12)
  minAmount                 Float         @default(10000)
  maxAmount                 Float         @default(10000000)
  processingFeePercent      Float         @default(1)
  processingFeeMin          Float         @default(500)
  processingFeeMax          Float         @default(10000)
  latePaymentPenaltyPercent Float         @default(2)
  gracePeriodDays           Int           @default(5)
  bounceCharges             Float         @default(500)
  allowMoratorium           Boolean       @default(true)
  maxMoratoriumMonths       Int           @default(3)
  allowPrepayment           Boolean       @default(true)
  prepaymentCharges         Float         @default(2)
  isPermanent               Boolean       @default(false) // Cannot be deleted if true
  isActive                  Boolean       @default(true)
  order                     Int           @default(0)
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  // Relations
  offlineLoans              OfflineLoan[]
}

model CMSBanner {
  id         String   @id @default(cuid())
  title      String
  subtitle   String?
  imageUrl   String?
  linkUrl    String?
  buttonText String?
  isActive   Boolean  @default(true)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CMSTestimonial {
  id           String   @id @default(cuid())
  customerName String
  designation  String?
  content      String
  rating       Int      @default(5)
  imageUrl     String?
  isActive     Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model FormConfig {
  id        String   @id @default(cuid())
  formType  String   @unique
  fields    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UploadedFile {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  uploadedBy   String?
  createdAt    DateTime @default(now())

  @@index([uploadedBy])
}

// ==================== ACCOUNTING MODULE ====================

// Chart of Accounts - Master ledger accounts
model ChartOfAccount {
  id              String             @id @default(cuid())
  companyId       String             @default("default") // Company this account belongs to
  accountCode     String
  accountName     String
  accountType     AccountType
  parentAccountId String?
  parentAccount   ChartOfAccount?    @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  subAccounts     ChartOfAccount[]   @relation("AccountHierarchy")
  description     String?
  isSystemAccount Boolean            @default(false)
  isActive        Boolean            @default(true)
  openingBalance  Float              @default(0)
  currentBalance  Float              @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  journalLines    JournalEntryLine[]
  ledgerBalances  LedgerBalance[]
  company         Company?           @relation(fields: [companyId], references: [id])

  @@unique([companyId, accountCode])
  @@index([companyId])
  @@index([accountCode])
  @@index([accountType])
  @@index([isActive])
}

// Financial Years
model FinancialYear {
  id               String          @id @default(cuid())
  companyId        String          @default("default") // Company this financial year belongs to
  name             String
  startDate        DateTime
  endDate          DateTime
  isClosed         Boolean         @default(false)
  closedAt         DateTime?
  closedById       String?
  previousYearId   String?
  carryForwardDone Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  ledgerBalances   LedgerBalance[]
  company          Company?        @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
  @@index([companyId])
  @@index([startDate])
  @@index([endDate])
  @@index([isClosed])
}

// Ledger Balances - Year-wise account balances
model LedgerBalance {
  id              String         @id @default(cuid())
  accountId       String
  financialYearId String
  openingBalance  Float          @default(0)
  totalDebits     Float          @default(0)
  totalCredits    Float          @default(0)
  closingBalance  Float          @default(0)
  account         ChartOfAccount @relation(fields: [accountId], references: [id])
  financialYear   FinancialYear  @relation(fields: [financialYearId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([accountId, financialYearId])
  @@index([accountId])
  @@index([financialYearId])
}

// Journal Entries - Main entry header
model JournalEntry {
  id            String             @id @default(cuid())
  companyId     String             @default("default") // Company this journal entry belongs to
  entryNumber   String
  entryDate     DateTime
  referenceType String? // LOAN_DISBURSEMENT, EMI_PAYMENT, FEE_COLLECTION, MANUAL, etc.
  referenceId   String? // Loan ID, Payment ID, etc.
  narration     String?
  totalDebit    Float              @default(0)
  totalCredit   Float              @default(0)
  isAutoEntry   Boolean            @default(false)
  isReversed    Boolean            @default(false)
  reversedById  String?
  reversedAt    DateTime?
  isApproved    Boolean            @default(false)
  approvedById  String?
  approvedAt    DateTime?
  createdById   String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  // Payment details for tracking
  paymentMode   String? // CASH, BANK_TRANSFER, CHEQUE, UPI, etc.
  chequeNumber  String?
  chequeDate    DateTime?
  bankRefNumber String?
  bankAccountId String?
  lines         JournalEntryLine[]
  company       Company?           @relation(fields: [companyId], references: [id])

  @@unique([companyId, entryNumber])
  @@index([companyId])
  @@index([entryNumber])
  @@index([entryDate])
  @@index([referenceType])
  @@index([referenceId])
  @@index([isAutoEntry])
  @@index([isApproved])
  @@index([paymentMode])
  @@index([bankAccountId])
  @@index([companyId, entryDate]) // compound: daybook date range per company
  @@index([referenceId, referenceType]) // compound: find journal entry by reference
}

// Journal Entry Lines - Individual debit/credit lines
model JournalEntryLine {
  id             String         @id @default(cuid())
  journalEntryId String
  accountId      String
  debitAmount    Float          @default(0)
  creditAmount   Float          @default(0)
  narration      String?
  loanId         String?
  customerId     String?
  runningBalance Float?         @default(0)
  balanceType    String? // DEBIT or CREDIT
  createdAt      DateTime       @default(now())
  account        ChartOfAccount @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@index([accountId])
  @@index([loanId])
  @@index([customerId])
}

// Reports Cache - Store generated reports
model ReportsCache {
  id            String    @id @default(cuid())
  reportType    String
  reportName    String
  parameters    String // JSON string of parameters
  generatedAt   DateTime  @default(now())
  data          String // JSON string of report data
  generatedById String
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  @@index([reportType])
  @@index([generatedAt])
  @@index([generatedById])
}

// Expense Management
model Expense {
  id               String    @id @default(cuid())
  companyId        String    @default("default") // Company this expense belongs to
  expenseNumber    String
  expenseType      String // SALARY, RENT, MARKETING, COMMISSION, etc.
  description      String
  amount           Float
  paymentDate      DateTime
  paymentMode      String // CASH, BANK_TRANSFER, CHEQUE, etc.
  paymentReference String?
  payeeName        String?
  payeeId          String?
  categoryId       String?
  isApproved       Boolean   @default(false)
  approvedById     String?
  approvedAt       DateTime?
  createdById      String
  receiptUrl       String?
  remarks          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  company          Company?  @relation(fields: [companyId], references: [id])

  @@unique([companyId, expenseNumber])
  @@index([companyId])
  @@index([expenseNumber])
  @@index([expenseType])
  @@index([paymentDate])
  @@index([isApproved])
}

// Bank Transaction Log - Tracks all bank movements
model BankTransaction {
  id              String      @id @default(cuid())
  bankAccountId   String
  transactionType String // CREDIT (money in) or DEBIT (money out)
  amount          Float
  balanceAfter    Float // Balance after this transaction
  description     String
  referenceType   String // LOAN_DISBURSEMENT, EMI_PAYMENT, EXPENSE, etc.
  referenceId     String? // ID of the related record
  createdById     String
  transactionDate DateTime    @default(now())
  createdAt       DateTime    @default(now())
  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id])

  @@index([bankAccountId])
  @@index([transactionDate])
  @@index([referenceType])
}

// GST Configuration
model GSTConfig {
  id             String    @id @default(cuid())
  companyId      String    @default("default") // Company this GST config belongs to
  gstRate        Float
  gstType        String // CGST, SGST, IGST
  applicableFrom DateTime
  applicableTo   DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  company        Company?  @relation(fields: [companyId], references: [id])

  @@unique([companyId, gstType, applicableFrom])
  @@index([companyId])
  @@index([gstType])
  @@index([isActive])
}

// Bank Accounts
model BankAccount {
  id             String  @id @default(cuid())
  companyId      String  @default("default") // Company this bank account belongs to
  bankName       String
  accountNumber  String
  accountName    String
  ownerName      String? // Bank account owner's name
  branchName     String?
  ifscCode       String?
  accountType    String // SAVINGS, CURRENT, etc.
  openingBalance Float   @default(0)
  currentBalance Float   @default(0)
  isActive       Boolean @default(true)
  isDefault      Boolean @default(false)

  // Payment Display Settings (for customer payment page)
  upiId     String? // UPI ID for receiving payments
  qrCodeUrl String? @db.Text // QR Code image (base64 data URL or file URL)

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  company      Company?          @relation(fields: [companyId], references: [id])
  transactions BankTransaction[]

  @@unique([companyId, accountNumber])
  @@index([companyId])
  @@index([accountNumber])
  @@index([isActive])
}

// Cash Book - For Company 3 (no bank account, uses cash only)
model CashBook {
  id              String          @id @default(cuid())
  companyId       String          @unique // One cash book per company (Company 3)
  openingBalance  Float           @default(0) // Opening balance for the financial year
  currentBalance  Float           @default(0) // Can be positive or negative
  lastUpdatedById String? // Who last updated the balance
  lastUpdatedAt   DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  company         Company         @relation(fields: [companyId], references: [id])
  entries         CashBookEntry[]

  @@index([companyId])
}

// Cash Book Entries - Track all cash movements
model CashBookEntry {
  id            String   @id @default(cuid())
  cashBookId    String
  entryType     String // CREDIT (money in) or DEBIT (money out)
  amount        Float
  balanceAfter  Float // Balance after this entry
  description   String
  referenceType String // LOAN_DISBURSEMENT, EMI_PAYMENT, MANUAL_ENTRY, etc.
  referenceId   String? // ID of the related record
  createdById   String // Who made this entry
  entryDate     DateTime @default(now())
  createdAt     DateTime @default(now())
  cashBook      CashBook @relation(fields: [cashBookId], references: [id])

  @@index([cashBookId])
  @@index([entryDate])
  @@index([referenceType])
  @@index([cashBookId, entryDate]) // compound: cashbook history by date range
  @@index([referenceId, referenceType]) // compound: find cashbook entry by reference
}

// Accounting Settings
model AccountingSettings {
  id                 String   @id @default(cuid())
  companyId          String   @unique
  financialYearStart Int      @default(4) // Month (April = 4)
  financialYearEnd   Int      @default(3) // Month (March = 3)
  currency           String   @default("INR")
  currencySymbol     String   @default("₹")
  decimalPlaces      Int      @default(2)
  enableGST          Boolean  @default(false)
  gstNumber          String?
  gstRate            Float    @default(18)
  enableTDS          Boolean  @default(false)
  tdsRate            Float    @default(10)
  fiscalYearPrefix   String   @default("FY")
  journalEntryPrefix String   @default("JE")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// Account Head - Simplified chart of accounts for daybook
model AccountHead {
  id             String         @id @default(cuid())
  companyId      String
  headCode       String
  headName       String
  headType       String // ASSET, LIABILITY, INCOME, EXPENSE, EQUITY
  isSystemHead   Boolean        @default(false)
  isActive       Boolean        @default(true)
  openingBalance Float          @default(0)
  currentBalance Float          @default(0)
  description    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  daybookEntries DaybookEntry[]

  @@unique([companyId, headCode])
  @@index([companyId])
  @@index([headCode])
  @@index([headType])
}

// Daybook Entry - All transactions recorded here
model DaybookEntry {
  id              String      @id @default(cuid())
  companyId       String
  entryNumber     String
  entryDate       DateTime
  accountHeadId   String
  accountHeadName String
  accountType     String // ASSET, LIABILITY, INCOME, EXPENSE, EQUITY
  particular      String
  referenceType   String // LOAN_DISBURSEMENT, EMI_PAYMENT, EXPENSE, etc.
  referenceId     String?
  debit           Float       @default(0)
  credit          Float       @default(0)
  sourceType      String // ONLINE_LOAN, OFFLINE_LOAN, MANUAL, etc.
  sourceId        String?
  loanNo          String?
  customerName    String?
  paymentMode     String?
  createdById     String
  createdAt       DateTime    @default(now())
  accountHead     AccountHead @relation(fields: [accountHeadId], references: [id])

  @@unique([companyId, entryNumber])
  @@index([companyId])
  @@index([entryDate])
  @@index([referenceType])
  @@index([referenceId])
  @@index([accountHeadId])
}

// Borrowed Money - Track money borrowed from external sources
model BorrowedMoney {
  id             String    @id @default(cuid())
  companyId      String
  sourceType     String // BANK, NBFC, INDIVIDUAL, etc.
  sourceName     String
  sourceId       String?
  amount         Float
  interestRate   Float?
  dueDate        DateTime?
  borrowedDate   DateTime
  description    String?
  amountRepaid   Float     @default(0)
  status         String    @default("ACTIVE") // ACTIVE, PARTIALLY_PAID, FULLY_PAID
  journalEntryId String?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([companyId])
  @@index([sourceType])
  @@index([status])
}

// Invest Money - Track investments made by the company
model InvestMoney {
  id             String    @id @default(cuid())
  companyId      String
  investmentType String // FIXED_DEPOSIT, MUTUAL_FUND, STOCKS, etc.
  investmentName String
  amount         Float
  interestRate   Float?
  maturityDate   DateTime?
  investedDate   DateTime
  description    String?
  currentValue   Float?
  status         String    @default("ACTIVE") // ACTIVE, MATURED, WITHDRAWN
  journalEntryId String?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([companyId])
  @@index([investmentType])
  @@index([status])
}

// Equity Entry - Track owner's equity movements
model EquityEntry {
  id             String   @id @default(cuid())
  companyId      String
  entryType      String // OPENING, ADDITIONAL, WITHDRAWAL
  amount         Float
  description    String?
  entryDate      DateTime
  journalEntryId String?
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyId])
  @@index([entryType])
}

// AI Chat History - Store chat conversations
model AIChatHistory {
  id          String   @id @default(cuid())
  customerId  String
  sessionId   String
  userMessage String
  aiResponse  String
  intent      String?
  createdAt   DateTime @default(now())

  @@index([customerId])
  @@index([sessionId])
  @@index([createdAt])
}

// Interest Only Loan - Track interest-only loans separately
model InterestOnlyLoan {
  id                      String                @id @default(cuid())
  loanApplicationId       String                @unique
  principalAmount         Float
  interestRate            Float
  interestOnlyRate        Float? // Interest rate during interest-only phase
  monthlyInterestAmount   Float
  totalInterestPaid       Float                 @default(0)
  totalMonthsPaid         Int                   @default(0)
  currentPhase            String                @default("INTEREST_ONLY") // INTEREST_ONLY or EMI_PHASE
  startDate               DateTime
  interestOnlyStartDate   DateTime?
  interestOnlyEndDate     DateTime?
  lastPaymentDate         DateTime?
  nextPaymentDueDate      DateTime?
  convertedToNormalAt     DateTime?
  isActive                Boolean               @default(true)
  // EMI Phase fields
  emiInterestRate         Float?
  emiTenureMonths         Int?
  emiAmount               Float?
  totalInterestInEmiPhase Float?
  totalAmountInEmiPhase   Float?
  emiPhaseStartDate       DateTime?
  startedEmiPhase         Boolean               @default(false)
  startedEmiPhaseById     String?
  startedEmiPhaseAt       DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  loanApplication         LoanApplication       @relation(fields: [loanApplicationId], references: [id])
  startedEmiPhaseBy       User?                 @relation(fields: [startedEmiPhaseById], references: [id])
  interestPayments        InterestOnlyPayment[]

  @@index([loanApplicationId])
  @@index([currentPhase])
  @@index([isActive])
}

// Interest Only Payment - Track monthly interest payments
model InterestOnlyPayment {
  id                 String           @id @default(cuid())
  interestOnlyLoanId String
  paymentMonth       Int
  paymentYear        Int
  dueDate            DateTime
  interestAmount     Float
  paidAmount         Float            @default(0)
  paidDate           DateTime?
  paymentMode        String?
  paymentReference   String?
  utrNumber          String?
  receiptNumber      String?
  status             String           @default("PENDING") // PENDING, PAID, OVERDUE, WAIVED
  isOverdue          Boolean          @default(false)
  daysOverdue        Int              @default(0)
  penaltyAmount      Float            @default(0)
  waivedAmount       Float            @default(0)
  waiverReason       String?
  waivedById         String?
  waivedAt           DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  interestOnlyLoan   InterestOnlyLoan @relation(fields: [interestOnlyLoanId], references: [id])

  @@index([interestOnlyLoanId])
  @@index([status])
  @@index([dueDate])
}

// Company Accounting Settings Extension
model CompanyAccountingSettings {
  id                        String   @id @default(cuid())
  companyId                 String   @unique
  defaultBankAccountId      String?
  autoJournalEntries        Boolean  @default(true)
  requireApproval           Boolean  @default(false)
  approvalThreshold         Float    @default(100000)
  enableCostCenter          Boolean  @default(false)
  enableProjectAccounting   Boolean  @default(false)
  retainedEarningsAccountId String?
  suspenseAccountId         String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

// Account Types Enum
enum AccountType {
  ASSET
  LIABILITY
  INCOME
  EXPENSE
  EQUITY
}

enum UserRole {
  SUPER_ADMIN
  COMPANY
  AGENT
  STAFF
  CASHIER
  CUSTOMER
  ACCOUNTANT
}

enum LoanStatus {
  SUBMITTED
  SA_APPROVED
  COMPANY_APPROVED
  AGENT_APPROVED_STAGE1
  LOAN_FORM_COMPLETED
  SESSION_CREATED
  CUSTOMER_SESSION_APPROVED
  FINAL_APPROVED
  DISBURSED
  ACTIVE
  ACTIVE_INTEREST_ONLY
  CLOSED
  REJECTED_BY_SA
  REJECTED_BY_COMPANY
  REJECTED_FINAL
  SESSION_REJECTED
}

enum LoanType {
  PERSONAL
  BUSINESS
  HOME
  VEHICLE
  EDUCATION
  GOLD
  OTHER
  INTEREST_ONLY
}

enum EMIPaymentStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  OVERDUE
  INTEREST_ONLY_PAID
  WAIVED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentType {
  FULL_EMI
  PARTIAL_PAYMENT
  INTEREST_ONLY
  INTEREST_ONLY_PAYMENT // Monthly interest payment during interest-only phase
