generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AIChatHistory {
  id          String   @id
  customerId  String
  sessionId   String
  userMessage String
  aiResponse  String
  intent      String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([sessionId])
  @@index([customerId])
}

model AccountHead {
  id             String         @id
  companyId      String
  headCode       String
  headName       String
  headType       String
  isSystemHead   Boolean        @default(false)
  isActive       Boolean        @default(true)
  openingBalance Float          @default(0)
  currentBalance Float          @default(0)
  description    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  DaybookEntry   DaybookEntry[]

  @@unique([companyId, headCode])
  @@index([headType])
  @@index([headCode])
  @@index([companyId])
}

model AccountingSettings {
  id                 String   @id
  companyId          String   @unique
  financialYearStart Int      @default(4)
  financialYearEnd   Int      @default(3)
  currency           String   @default("INR")
  currencySymbol     String   @default("₹")
  decimalPlaces      Int      @default(2)
  enableGST          Boolean  @default(false)
  gstNumber          String?
  gstRate            Float    @default(18)
  enableTDS          Boolean  @default(false)
  tdsRate            Float    @default(10)
  fiscalYearPrefix   String   @default("FY")
  journalEntryPrefix String   @default("JE")
  createdAt          DateTime @default(now())
  updatedAt          DateTime
}

model ActionLog {
  id                              String    @id
  userId                          String
  userRole                        String
  actionType                      String
  module                          String
  recordId                        String
  recordType                      String
  previousData                    String?
  newData                         String?
  canUndo                         Boolean   @default(true)
  isUndone                        Boolean   @default(false)
  undoneAt                        DateTime?
  undoneById                      String?
  canRedo                         Boolean   @default(false)
  isRedone                        Boolean   @default(false)
  redoneAt                        DateTime?
  redoneById                      String?
  description                     String
  ipAddress                       String?
  userAgent                       String?
  createdAt                       DateTime  @default(now())
  updatedAt                       DateTime
  User_ActionLog_redoneByIdToUser User?     @relation("ActionLog_redoneByIdToUser", fields: [redoneById], references: [id])
  User_ActionLog_undoneByIdToUser User?     @relation("ActionLog_undoneByIdToUser", fields: [undoneById], references: [id])
  User_ActionLog_userIdToUser     User      @relation("ActionLog_userIdToUser", fields: [userId], references: [id])

  @@index([recordId])
  @@index([module])
  @@index([actionType])
  @@index([userId])
}

model AgentPerformance {
  id                String   @id
  agentId           String
  companyId         String
  month             String
  totalDisbursed    Float    @default(0)
  totalApplications Int      @default(0)
  approvedCount     Int      @default(0)
  rejectedCount     Int      @default(0)
  approvalRatio     Float    @default(0)
  defaultCount      Int      @default(0)
  defaultRatio      Float    @default(0)
  commissionEarned  Float    @default(0)
  slabId            String?
  isFlagged         Boolean  @default(false)
  flagReason        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime
  Company           Company  @relation(fields: [companyId], references: [id])
  User              User     @relation(fields: [agentId], references: [id])

  @@unique([agentId, month])
  @@index([companyId])
  @@index([agentId])
}

model ApplicationFingerprint {
  id                String          @id
  panNumber         String?
  phoneNumber       String?
  emailAddress      String?
  deviceId          String?
  ipAddress         String?
  loanApplicationId String
  isDuplicate       Boolean         @default(false)
  matchedWith       String?
  createdAt         DateTime        @default(now())
  LoanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])

  @@index([deviceId])
  @@index([emailAddress])
  @@index([phoneNumber])
  @@index([panNumber])
}

model Appointment {
  id                String           @id
  loanApplicationId String?
  customerId        String
  staffId           String?
  scheduledAt       DateTime
  type              String
  location          String?
  latitude          Float?
  longitude         Float?
  status            String           @default("SCHEDULED")
  notes             String?
  checkInAt         DateTime?
  checkInLatitude   Float?
  checkInLongitude  Float?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime
  LoanApplication   LoanApplication? @relation(fields: [loanApplicationId], references: [id])

  @@index([status])
  @@index([staffId])
  @@index([customerId])
}

model AssetDepreciationLog {
  id                 String     @id
  assetId            String
  depreciationDate   DateTime
  financialYear      String
  period             String
  openingBookValue   Float
  depreciationAmount Float
  closingBookValue   Float
  journalEntryId     String?
  calculatedAt       DateTime   @default(now())
  calculatedById     String
  FixedAsset         FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([financialYear])
  @@index([depreciationDate])
  @@index([assetId])
}

model AuditLog {
  id                String           @id
  userId            String
  loanApplicationId String?
  paymentId         String?
  action            String
  module            String
  description       String
  oldValue          String?
  newValue          String?
  ipAddress         String?
  userAgent         String?
  location          String?
  recordId          String?
  recordType        String?
  createdAt         DateTime         @default(now())
  User              User             @relation(fields: [userId], references: [id])
  LoanApplication   LoanApplication? @relation(fields: [loanApplicationId], references: [id])
  Payment           Payment?         @relation(fields: [paymentId], references: [id])

  @@index([createdAt])
  @@index([action])
  @@index([module])
  @@index([userId])
}

model BankAccount {
  id              String            @id
  companyId       String            @default("default")
  bankName        String
  accountNumber   String
  accountName     String
  ownerName       String?
  branchName      String?
  ifscCode        String?
  accountType     String
  openingBalance  Float             @default(0)
  currentBalance  Float             @default(0)
  isActive        Boolean           @default(true)
  isDefault       Boolean           @default(false)
  upiId           String?
  qrCodeUrl       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  Company         Company           @relation(fields: [companyId], references: [id])
  BankTransaction BankTransaction[]

  @@unique([companyId, accountNumber])
  @@index([isActive])
  @@index([accountNumber])
  @@index([companyId])
}

model BankTransaction {
  id              String      @id
  bankAccountId   String
  transactionType String
  amount          Float
  balanceAfter    Float
  description     String
  referenceType   String
  referenceId     String?
  createdById     String
  transactionDate DateTime    @default(now())
  createdAt       DateTime    @default(now())
  BankAccount     BankAccount @relation(fields: [bankAccountId], references: [id])

  @@index([referenceType])
  @@index([transactionDate])
  @@index([bankAccountId])
}

model Blacklist {
  id            String   @id
  userId        String
  reason        String
  blacklistedAt DateTime @default(now())
  blacklistedBy String?
  User          User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model BorrowedMoney {
  id             String    @id
  companyId      String
  sourceType     String
  sourceName     String
  sourceId       String?
  amount         Float
  interestRate   Float?
  dueDate        DateTime?
  borrowedDate   DateTime
  description    String?
  amountRepaid   Float     @default(0)
  status         String    @default("ACTIVE")
  journalEntryId String?
  createdById    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime

  @@index([status])
  @@index([sourceType])
  @@index([companyId])
}

model CMSBanner {
  id         String   @id
  title      String
  subtitle   String?
  imageUrl   String?
  linkUrl    String?
  buttonText String?
  isActive   Boolean  @default(true)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime
}

model CMSService {
  id                        String        @id
  title                     String
  description               String
  icon                      String?
  code                      String        @unique @default("LN")
  loanType                  String        @default("PERSONAL")
  isInterestOnly            Boolean       @default(false)
  minInterestRate           Float         @default(8)
  maxInterestRate           Float         @default(24)
  defaultInterestRate       Float         @default(12)
  minTenure                 Int           @default(6)
  maxTenure                 Int           @default(60)
  defaultTenure             Int           @default(12)
  minAmount                 Float         @default(10000)
  maxAmount                 Float         @default(10000000)
  processingFeePercent      Float         @default(1)
  processingFeeMin          Float         @default(500)
  processingFeeMax          Float         @default(10000)
  latePaymentPenaltyPercent Float         @default(2)
  gracePeriodDays           Int           @default(5)
  bounceCharges             Float         @default(500)
  allowMoratorium           Boolean       @default(true)
  maxMoratoriumMonths       Int           @default(3)
  allowPrepayment           Boolean       @default(true)
  prepaymentCharges         Float         @default(2)
  isPermanent               Boolean       @default(false)
  isActive                  Boolean       @default(true)
  order                     Int           @default(0)
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime
  OfflineLoan               OfflineLoan[]
}

model CMSTestimonial {
  id           String   @id
  customerName String
  designation  String?
  content      String
  rating       Int      @default(5)
  imageUrl     String?
  isActive     Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime
}

model CashBook {
  id              String          @id
  companyId       String          @unique
  openingBalance  Float           @default(0)
  currentBalance  Float           @default(0)
  lastUpdatedById String?
  lastUpdatedAt   DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  Company         Company         @relation(fields: [companyId], references: [id])
  CashBookEntry   CashBookEntry[]

  @@index([companyId])
}

model CashBookEntry {
  id            String   @id
  cashBookId    String
  entryType     String
  amount        Float
  balanceAfter  Float
  description   String
  referenceType String
  referenceId   String?
  createdById   String
  entryDate     DateTime @default(now())
  createdAt     DateTime @default(now())
  CashBook      CashBook @relation(fields: [cashBookId], references: [id])

  @@index([referenceId, referenceType])
  @@index([cashBookId, entryDate])
  @@index([referenceType])
  @@index([entryDate])
  @@index([cashBookId])
}

model CashierSettlement {
  id                                     String              @id
  settlementNumber                       String              @unique
  userId                                 String
  cashierId                              String
  amount                                 Float
  paymentMode                            String
  chequeNumber                           String?
  chequeDate                             DateTime?
  bankRefNumber                          String?
  utrNumber                              String?
  status                                 String              @default("PENDING")
  verifiedById                           String?
  verifiedAt                             DateTime?
  cashDenominations                      String?
  remarks                                String?
  rejectionReason                        String?
  createdAt                              DateTime            @default(now())
  updatedAt                              DateTime
  User_CashierSettlement_cashierIdToUser User                @relation("CashierSettlement_cashierIdToUser", fields: [cashierId], references: [id])
  User_CashierSettlement_userIdToUser    User                @relation("CashierSettlement_userIdToUser", fields: [userId], references: [id])
  CreditTransaction                      CreditTransaction[]

  @@index([createdAt])
  @@index([paymentMode])
  @@index([status])
  @@index([cashierId])
  @@index([userId])
}

model ChartOfAccount {
  id                   String             @id
  companyId            String             @default("default")
  accountCode          String
  accountName          String
  accountType          String
  parentAccountId      String?
  description          String?
  isSystemAccount      Boolean            @default(false)
  isActive             Boolean            @default(true)
  openingBalance       Float              @default(0)
  currentBalance       Float              @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime
  Company              Company            @relation(fields: [companyId], references: [id])
  ChartOfAccount       ChartOfAccount?    @relation("ChartOfAccountToChartOfAccount", fields: [parentAccountId], references: [id])
  other_ChartOfAccount ChartOfAccount[]   @relation("ChartOfAccountToChartOfAccount")
  JournalEntryLine     JournalEntryLine[]
  LedgerBalance        LedgerBalance[]

  @@unique([companyId, accountCode])
  @@index([isActive])
  @@index([accountType])
  @@index([accountCode])
  @@index([companyId])
}

model ChatbotMessage {
  id               String         @id
  sessionId        String
  senderType       String
  message          String
  intent           String?
  entities         String?
  confidence       Float?
  needsEscalation  Boolean        @default(false)
  escalationReason String?
  suggestedActions String?
  createdAt        DateTime       @default(now())
  ChatbotSession   ChatbotSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([senderType])
  @@index([sessionId])
}

model ChatbotSession {
  id                  String           @id
  customerId          String
  status              String           @default("ACTIVE")
  escalationTicketId  String?
  contextData         String?
  messageCount        Int              @default(0)
  conversationHistory String?
  startedAt           DateTime         @default(now())
  endedAt             DateTime?
  lastMessageAt       DateTime         @default(now())
  ChatbotMessage      ChatbotMessage[]
  User                User             @relation(fields: [customerId], references: [id])

  @@index([startedAt])
  @@index([status])
  @@index([customerId])
}

model CommissionSlab {
  id               String   @id
  companyId        String
  name             String
  minDisbursement  Float    @default(0)
  maxDisbursement  Float?
  commissionRate   Float
  minApprovalRatio Float    @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime
  Company          Company  @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model Company {
  id                                                             String                  @id
  name                                                           String
  code                                                           String                  @unique
  registrationNo                                                 String?
  gstNumber                                                      String?
  panNumber                                                      String?
  address                                                        String?
  city                                                           String?
  state                                                          String?
  pincode                                                        String?
  country                                                        String?                 @default("India")
  contactEmail                                                   String?
  contactPhone                                                   String?
  website                                                        String?
  ownerName                                                      String?
  ownerPhone                                                     String?
  ownerEmail                                                     String?
  ownerAadhaar                                                   String?
  ownerPan                                                       String?
  logoUrl                                                        String?
  isActive                                                       Boolean                 @default(true)
  maxLoanAmount                                                  Float                   @default(10000000)
  minLoanAmount                                                  Float                   @default(10000)
  defaultInterestRate                                            Float                   @default(12)
  maxTenureMonths                                                Int                     @default(60)
  companyCredit                                                  Float                   @default(0)
  myCash                                                         Float                   @default(0)
  defaultInterestType                                            String                  @default("FLAT")
  enableMirrorLoan                                               Boolean                 @default(false)
  mirrorInterestRate                                             Float?
  mirrorInterestType                                             String?
  isMirrorCompany                                                Boolean                 @default(true)
  accountingType                                                 String                  @default("FULL")
  createdAt                                                      DateTime                @default(now())
  updatedAt                                                      DateTime
  deletedAt                                                      DateTime?
  AgentPerformance                                               AgentPerformance[]
  BankAccount                                                    BankAccount[]
  CashBook                                                       CashBook?
  ChartOfAccount                                                 ChartOfAccount[]
  CommissionSlab                                                 CommissionSlab[]
  CompanyPaymentPage                                             CompanyPaymentPage?
  CompanyPaymentSettings                                         CompanyPaymentSettings?
  Expense                                                        Expense[]
  FinancialYear                                                  FinancialYear[]
  FixedAsset                                                     FixedAsset[]
  GSTConfig                                                      GSTConfig[]
  GracePeriodConfig                                              GracePeriodConfig[]
  JournalEntry                                                   JournalEntry[]
  Ledger                                                         Ledger[]
  LoanApplication                                                LoanApplication[]
  MirrorLoanMapping_MirrorLoanMapping_originalCompanyIdToCompany MirrorLoanMapping[]     @relation("MirrorLoanMapping_originalCompanyIdToCompany")
  MirrorLoanMapping_MirrorLoanMapping_mirrorCompanyIdToCompany   MirrorLoanMapping[]     @relation("MirrorLoanMapping_mirrorCompanyIdToCompany")
  OfflineLoan                                                    OfflineLoan[]
  PendingMirrorLoan_PendingMirrorLoan_originalCompanyIdToCompany PendingMirrorLoan[]     @relation("PendingMirrorLoan_originalCompanyIdToCompany")
  PendingMirrorLoan_PendingMirrorLoan_mirrorCompanyIdToCompany   PendingMirrorLoan[]     @relation("PendingMirrorLoan_mirrorCompanyIdToCompany")
  PreApprovedOffer                                               PreApprovedOffer[]
  SecondaryPaymentPage                                           SecondaryPaymentPage[]
  User                                                           User[]

  @@index([code])
}

model CompanyAccountingSettings {
  id                        String   @id
  companyId                 String   @unique
  defaultBankAccountId      String?
  autoJournalEntries        Boolean  @default(true)
  requireApproval           Boolean  @default(false)
  approvalThreshold         Float    @default(100000)
  enableCostCenter          Boolean  @default(false)
  enableProjectAccounting   Boolean  @default(false)
  retainedEarningsAccountId String?
  suspenseAccountId         String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime
}

model CompanyPaymentPage {
  id                     String   @id
  companyId              String   @unique
  upiId                  String?
  qrCodeUrl              String?
  bankAccountId          String?  @unique
  bankName               String?
  accountNumber          String?
  accountName            String?
  ifscCode               String?
  secondaryPaymentRoleId String?
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime
  User                   User?    @relation(fields: [secondaryPaymentRoleId], references: [id])
  Company                Company  @relation(fields: [companyId], references: [id])

  @@index([bankAccountId])
  @@index([isActive])
  @@index([companyId])
}

model CompanyPaymentSettings {
  id                       String   @id
  companyId                String   @unique
  enableFullPayment        Boolean  @default(true)
  enablePartialPayment     Boolean  @default(true)
  enableInterestOnly       Boolean  @default(true)
  maxPartialPaymentsPerEMI Int      @default(2)
  partialPaymentFeePercent Float    @default(0)
  allowDateChangeOnPartial Boolean  @default(true)
  maxInterestOnlyPayments  Int      @default(3)
  interestOnlyFeePercent   Float    @default(0)
  addNewEMIOnInterestOnly  Boolean  @default(true)
  acceptedMethods          String   @default("UPI,BANK_TRANSFER,CASH")
  companyUpiId             String?
  companyQrCodeUrl         String?
  collectionBankAccountId  String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime
  Company                  Company  @relation(fields: [companyId], references: [id])
}

model ContactEnquiry {
  id          String    @id
  name        String
  email       String
  phone       String
  message     String
  status      String    @default("PENDING")
  notes       String?
  contactedAt DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime

  @@index([createdAt])
  @@index([status])
}

model CounterOffer {
  id                String          @id
  loanApplicationId String
  offeredById       String
  offeredToId       String
  offeredAmount     Float
  interestRate      Float
  tenure            Int
  message           String?
  status            String          @default("PENDING")
  parentOfferId     String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime
  LoanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])

  @@index([status])
  @@index([loanApplicationId])
}

model CreditRiskScore {
  id                String   @id
  loanApplicationId String?
  customerId        String
  score             Int
  factors           String?
  incomeRatio       Float?
  emiToIncomeRatio  Float?
  employmentScore   Int?
  repaymentHistory  Int?
  geoRiskScore      Int?
  createdAt         DateTime @default(now())
  User              User     @relation(fields: [customerId], references: [id])

  @@index([loanApplicationId])
  @@index([customerId])
}

model CreditTransaction {
  id                   String             @id
  userId               String
  transactionType      String
  amount               Float
  paymentMode          String
  creditType           String             @default("COMPANY")
  companyBalanceAfter  Float?
  personalBalanceAfter Float?
  balanceAfter         Float
  sourceType           String
  sourceId             String?
  loanApplicationId    String?
  emiScheduleId        String?
  customerId           String?
  installmentNumber    Int?
  customerName         String?
  customerPhone        String?
  loanApplicationNo    String?
  emiDueDate           DateTime?
  emiAmount            Float?
  principalComponent   Float?
  interestComponent    Float?
  chequeNumber         String?
  chequeDate           DateTime?
  bankRefNumber        String?
  utrNumber            String?
  description          String?
  remarks              String?
  proofDocument        String?
  proofType            String?
  proofUploadedAt      DateTime?
  proofVerified        Boolean            @default(false)
  proofVerifiedBy      String?
  proofVerifiedAt      DateTime?
  settlementId         String?
  collectedFrom        String?
  collectedFromPhone   String?
  collectionLocation   String?
  collectionLatitude   Float?
  collectionLongitude  Float?
  transactionDate      DateTime           @default(now())
  createdAt            DateTime           @default(now())
  updatedAt            DateTime
  CashierSettlement    CashierSettlement? @relation(fields: [settlementId], references: [id])
  User                 User               @relation(fields: [userId], references: [id])

  @@index([transactionDate])
  @@index([createdAt])
  @@index([customerId])
  @@index([loanApplicationId])
  @@index([sourceType])
  @@index([creditType])
  @@index([paymentMode])
  @@index([transactionType])
  @@index([userId])
}

model DailyCollection {
  id                   String   @id
  date                 DateTime @unique @default(now())
  totalCash            Float    @default(0)
  totalCheque          Float    @default(0)
  totalOnline          Float    @default(0)
  totalAmount          Float    @default(0)
  totalTransactions    Int      @default(0)
  emiPaymentsCount     Int      @default(0)
  settlementsCount     Int      @default(0)
  superAdminCollection Float    @default(0)
  companyCollection    Float    @default(0)
  agentCollection      Float    @default(0)
  staffCollection      Float    @default(0)
  cashierCollection    Float    @default(0)
  customerDirect       Float    @default(0)
  companyId            String?
  branchId             String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime

  @@index([companyId])
  @@index([date])
}

model DaybookEntry {
  id              String      @id
  companyId       String
  entryNumber     String
  entryDate       DateTime
  accountHeadId   String
  accountHeadName String
  accountType     String
  particular      String
  referenceType   String
  referenceId     String?
  debit           Float       @default(0)
  credit          Float       @default(0)
  sourceType      String
  sourceId        String?
  loanNo          String?
  customerName    String?
  paymentMode     String?
  createdById     String
  createdAt       DateTime    @default(now())
  AccountHead     AccountHead @relation(fields: [accountHeadId], references: [id])

  @@unique([companyId, entryNumber])
  @@index([accountHeadId])
  @@index([referenceId])
  @@index([referenceType])
  @@index([entryDate])
  @@index([companyId])
}

model DeviceFingerprint {
  id         String   @id
  userId     String
  deviceId   String
  deviceName String?
  lastUsed   DateTime @default(now())
  User       User     @relation(fields: [userId], references: [id])

  @@index([deviceId])
  @@index([userId])
}

model DocumentRequest {
  id                String          @id
  loanApplicationId String
  documentType      String
  reason            String
  status            String          @default("PENDING")
  requestedById     String
  uploadedAt        DateTime?
  verifiedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime
  LoanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])

  @@index([status])
  @@index([loanApplicationId])
}

model EMIDateChangeRequest {
  id                String          @id
  loanApplicationId String
  currentDueDate    Int
  requestedDueDate  Int
  reason            String?
  status            String          @default("PENDING")
  approvedById      String?
  approvedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime
  LoanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])

  @@index([status])
  @@index([loanApplicationId])
}

model EMIPaymentSetting {
  id                     String                @id
  emiScheduleId          String                @unique
  loanApplicationId      String
  enableFullPayment      Boolean               @default(true)
  enablePartialPayment   Boolean               @default(false)
  enableInterestOnly     Boolean               @default(false)
  enablePrincipalOnly    Boolean               @default(false)
  useDefaultCompanyPage  Boolean               @default(true)
  secondaryPaymentPageId String?
  lastModifiedById       String?
  lastModifiedAt         DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime
  User                   User?                 @relation(fields: [lastModifiedById], references: [id])
  SecondaryPaymentPage   SecondaryPaymentPage? @relation(fields: [secondaryPaymentPageId], references: [id])
  LoanApplication        LoanApplication       @relation(fields: [loanApplicationId], references: [id])
  EMISchedule            EMISchedule           @relation(fields: [emiScheduleId], references: [id])

