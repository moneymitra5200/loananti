// ==================== CREDIT & COLLECTION SYSTEM ====================

// Credit Transaction - Track all credit movements (EMI payments by roles)
model CreditTransaction {
  id              String                @id @default(cuid())
  userId          String // User whose credit is affected
  transactionType CreditTransactionType // CREDIT_INCREASE, CREDIT_DECREASE, SETTLEMENT, PERSONAL_CLEARANCE
  amount          Float // Amount involved
  paymentMode     PaymentModeType // CASH, CHEQUE, ONLINE, UPI, BANK_TRANSFER

  // Dual Credit System
  creditType           CreditType @default(COMPANY) // COMPANY or PERSONAL
  companyBalanceAfter  Float? // Company credit balance after this transaction
  personalBalanceAfter Float? // Personal credit balance after this transaction
  balanceAfter         Float // Total credit balance after this transaction (legacy)

  // Reference to what caused this transaction
  sourceType String // EMI_PAYMENT, SETTLEMENT, ADJUSTMENT, PERSONAL_COLLECTION
  sourceId   String? // Payment ID, Settlement ID, etc.

  // EMI Payment Details (when source is EMI_PAYMENT)
  loanApplicationId String?
  emiScheduleId     String?
  customerId        String?
  installmentNumber Int?

  // Customer Details (for quick reference without joins)
  customerName      String?
  customerPhone     String?
  loanApplicationNo String?

  // EMI Details (for quick reference)
  emiDueDate         DateTime?
  emiAmount          Float?
  principalComponent Float?
  interestComponent  Float?

  // Additional details
  chequeNumber  String?
  chequeDate    DateTime?
  bankRefNumber String?
  utrNumber     String?
  description   String?
  remarks       String?

  // Proof Document (required for CHEQUE, ONLINE, and PERSONAL transactions)
  proofDocument   String? // File path to uploaded proof
  proofType       String? // Type of proof (image, pdf, etc.)
  proofUploadedAt DateTime?
  proofVerified   Boolean   @default(false)
  proofVerifiedBy String?
  proofVerifiedAt DateTime?

  // For settlements
  settlementId String? // Reference to CashierSettlement

  // Collection Details
  collectedFrom       String? // Name of person who paid
  collectedFromPhone  String? // Phone of person who paid
  collectionLocation  String? // Location where payment was collected
  collectionLatitude  Float?
  collectionLongitude Float?

  // Timestamps
  transactionDate DateTime @default(now()) // When the actual transaction happened
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user       User               @relation("UserCreditTransactions", fields: [userId], references: [id])
  settlement CashierSettlement? @relation(fields: [settlementId], references: [id])

  @@index([userId])
  @@index([transactionType])
  @@index([paymentMode])
  @@index([creditType])
  @@index([sourceType])
  @@index([loanApplicationId])
  @@index([customerId])
  @@index([createdAt])
  @@index([transactionDate])
}

// Cashier Settlement - When role gives money to cashier
model CashierSettlement {
  id                 String              @id @default(cuid())
  settlementNumber   String              @unique
  userId             String // User giving the money
  cashierId          String // Cashier receiving the money
  amount             Float // Total amount settled
  paymentMode        PaymentModeType // CASH, CHEQUE, ONLINE
  // Payment details
  chequeNumber       String?
  chequeDate         DateTime?
  bankRefNumber      String?
  utrNumber          String?
  // Status
  status             SettlementStatus    @default(PENDING) // PENDING, VERIFIED, COMPLETED
  verifiedById       String? // Accountant who verified
  verifiedAt         DateTime?
  // Denomination breakdown for cash
  cashDenominations  String? // JSON string with denomination breakdown
  // Remarks
  remarks            String?
  rejectionReason    String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation("UserSettlements", fields: [userId], references: [id])
  cashier            User                @relation("CashierReceivedSettlements", fields: [cashierId], references: [id])
  creditTransactions CreditTransaction[]

  @@index([userId])
  @@index([cashierId])
  @@index([status])
  @@index([paymentMode])
  @@index([createdAt])
}

// Daily Collection Summary - Aggregated daily collection data
model DailyCollection {
  id                   String   @id @default(cuid())
  date                 DateTime @default(now())
  // Collection by mode
  totalCash            Float    @default(0)
  totalCheque          Float    @default(0)
  totalOnline          Float    @default(0)
  totalAmount          Float    @default(0)
  // Counts
  totalTransactions    Int      @default(0)
  emiPaymentsCount     Int      @default(0)
  settlementsCount     Int      @default(0)
  // Breakdown by role
  superAdminCollection Float    @default(0)
  companyCollection    Float    @default(0)
  agentCollection      Float    @default(0)
  staffCollection      Float    @default(0)
  cashierCollection    Float    @default(0)
  customerDirect       Float    @default(0)
  // Metadata
  companyId            String?
  branchId             String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([date])
  @@index([date])
  @@index([companyId])
}

// Credit Transaction Types Enum
enum CreditTransactionType {
  CREDIT_INCREASE // When role collects EMI payment
  CREDIT_DECREASE // When role settles with cashier/superadmin
  SETTLEMENT // When cashier receives payment
  ADJUSTMENT // Manual adjustment by admin
  PERSONAL_CLEARANCE // When personal credit is cleared by superadmin
  PERSONAL_COLLECTION // When money collected in personal account
  BANK_DIRECT // When customer pays directly to bank (Company Credit + ONLINE)
}

// Credit Type Enum - Dual Credit System
enum CreditType {
  COMPANY // Company credit - only CASH increases this
  PERSONAL // Personal credit - requires proof for all transactions
}

// Payment Mode Enum
enum PaymentModeType {
  CASH // Only CASH increases company credit
  CHEQUE // Requires proof, doesn't increase company credit
  ONLINE // Requires proof, doesn't increase company credit
  UPI // Requires proof, doesn't increase company credit
  BANK_TRANSFER // Requires proof, doesn't increase company credit
  SYSTEM // For system-generated transactions (deductions, transfers, etc.)
}

// Settlement Status Enum
enum SettlementStatus {
  PENDING
  VERIFIED
  COMPLETED
  REJECTED
}

// ==================== OFFLINE LOAN SYSTEM ====================

// Offline Loan - Created by SuperAdmin or Agent directly
model OfflineLoan {
  id                        String             @id @default(cuid())
  loanNumber                String             @unique
  // Creator info
  createdById               String // Who created this loan (SuperAdmin or Agent)
  createdByRole             String // SUPER_ADMIN, AGENT
  companyId                 String?
  // Customer info (can be new or existing)
  customerId                String? // Link to existing user if available
  customerName              String
  customerPhone             String
  customerEmail             String?
  customerAadhaar           String?
  customerPan               String?
  customerAddress           String?
  customerCity              String?
  customerState             String?
  customerPincode           String?
  customerDOB               DateTime?
  customerOccupation        String?
  customerMonthlyIncome     Float?
  // Reference contacts
  reference1Name            String?
  reference1Phone           String?
  reference1Relation        String?
  reference2Name            String?
  reference2Phone           String?
  reference2Relation        String?
  // Loan details
  loanType                  LoanType           @default(PERSONAL)
  interestType              String             @default("FLAT") // FLAT or REDUCING
  loanAmount                Float
  interestRate              Float
  tenure                    Int // in months
  emiAmount                 Float
  processingFee             Float              @default(0)
  disbursementDate          DateTime
  disbursementMode          String? // CASH, BANK_TRANSFER, CHEQUE
  disbursementRef           String? // Transaction reference
  // Status
  status                    OfflineLoanStatus  @default(ACTIVE)
  // Payment options control
  allowInterestOnly         Boolean            @default(true) // Allow interest-only payments
  allowPartialPayment       Boolean            @default(true) // Allow partial payments
  // Interest Only Loan specific fields
  isInterestOnlyLoan        Boolean            @default(false) // Is this an interest-only loan?
  interestOnlyStartDate     DateTime? // When interest-only phase started
  interestOnlyMonthlyAmount Float? // Monthly interest amount during interest-only phase
  loanStartedAt             DateTime? // When loan was converted from interest-only to normal
  totalInterestPaid         Float              @default(0) // Total interest collected during interest-only phase
  pendingInterestEMI        Boolean            @default(false) // Is there a pending interest EMI to pay?
  currentInterestEMIId      String? // Current pending interest EMI ID
  partialPaymentEnabled     Boolean            @default(false) // Can customer make partial payments? (disabled by default for interest-only)
  // Dates
  startDate                 DateTime // EMI start date
  closedAt                  DateTime?
  // Notes
  notes                     String?
  internalNotes             String?
  // Documents
  panCardDoc                String?   @db.LongText
  aadhaarFrontDoc           String?   @db.LongText
  aadhaarBackDoc            String?   @db.LongText
  incomeProofDoc            String?   @db.LongText
  addressProofDoc           String?   @db.LongText
  photoDoc                  String?   @db.LongText
  electionCardDoc           String?   @db.LongText
  housePhotoDoc             String?   @db.LongText
  guarantorPhotoDoc         String?   @db.LongText
  passbookPhotoDoc          String?   @db.LongText
  otherDocs                 String?   @db.LongText
  applicationLocation       String?
  // Product reference
  productId                 String? // Reference to CMSService (loan product)
  // Bank account for disbursement
  bankAccountId             String? // Bank account used for disbursement
  // Mirror Loan Display Color - Same color for original + mirror pair
  displayColor              String? // Hex color code like "#FF5733" - unique per loan pair
  // Mirror Loan Flag - READ-ONLY if true (EMI payments only on original loan)
  isMirrorLoan              Boolean            @default(false) // TRUE = This is a mirror loan (READ-ONLY, cannot pay EMI directly)
  originalLoanId            String? // If this is a mirror loan, reference to the original loan
  // Secondary Payment Page for C3 non-mirror loans
  // When C3 has no bank account, customer pays → cashbook entry + credit goes to this page's user
  secondaryPaymentPageId    String? // SecondaryPaymentPage.id for routing credit on C3 non-mirror EMI payments
  processingFeeRecorded     Boolean            @default(false) // Has processing fee been posted to accounting?
  // Timestamps
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
  // Relations
  emis                      OfflineLoanEMI[]
  createdBy                 User               @relation("OfflineLoanCreator", fields: [createdById], references: [id])
  company                   Company?           @relation(fields: [companyId], references: [id])
  customer                  User?              @relation("OfflineLoanCustomer", fields: [customerId], references: [id])
  product                   CMSService?        @relation(fields: [productId], references: [id])
  secondaryPaymentPage      SecondaryPaymentPage? @relation("OfflineLoanSecondaryPage", fields: [secondaryPaymentPageId], references: [id])
  // Loan Type Specific Details
  goldLoanDetail            GoldLoanDetail?
  vehicleLoanDetail         VehicleLoanDetail?

  @@index([loanNumber])
  @@index([createdById])
  @@index([customerId])
  @@index([status])
  @@index([disbursementDate])
  @@index([companyId, status]) // compound: admin list by company + status
  @@index([customerPhone]) // phone search
}

// Offline Loan EMI Schedule
model OfflineLoanEMI {
  id                   String           @id @default(cuid())
  offlineLoanId        String
  installmentNumber    Int
  dueDate              DateTime
  principalAmount      Float
  interestAmount       Float
  totalAmount          Float
  outstandingPrincipal Float
  // Payment tracking
  paidAmount           Float            @default(0)
  paidPrincipal        Float            @default(0)
  paidInterest         Float            @default(0)
  paymentStatus        EMIPaymentStatus @default(PENDING)
  paidDate             DateTime?
  paymentMode          String?
  paymentReference     String?
  // Penalty
  penaltyAmount        Float            @default(0)
  penaltyPaid          Float            @default(0)
  daysOverdue          Int              @default(0)
  // Collection tracking
  collectedById        String? // Who collected the payment
  collectedByName      String? // Name of collector
  collectedAt          DateTime?
  // Reminder tracking
  reminderSent         Boolean          @default(false)
  reminderSentAt       DateTime?
  // Deferred EMI tracking (for interest-only payments)
  isDeferred           Boolean          @default(false) // True if this EMI was deferred due to interest-only payment
  deferredFromEMI      Int? // Original EMI number this was deferred from
  // Interest Only EMI tracking
  isInterestOnly       Boolean          @default(false) // Is this an interest-only EMI?
  interestOnlyAmount   Float            @default(0) // Interest amount for interest-only EMI
  interestOnlyPaidAt   DateTime? // When interest-only was paid
  // Partial Payment tracking
  isPartialPayment     Boolean          @default(false) // Has this EMI been partially paid?
  nextPaymentDate      DateTime? // When the remaining amount will be paid
  remainingAmount      Float            @default(0) // Remaining amount after partial payment
  // Date shifting tracking
  originalDueDate      DateTime? // Original due date before shifting
  notes                String? // Additional notes
  // Timestamps
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  // Relations
  offlineLoan          OfflineLoan      @relation(fields: [offlineLoanId], references: [id], onDelete: Cascade)
  collector            User?            @relation(fields: [collectedById], references: [id])
  // Payment History JSON - stores array of payment records
  paymentHistoryJson   String?  @db.LongText // JSON array of {amount, principal, interest, penalty, mode, reference, paidAt, collectedBy}

  @@unique([offlineLoanId, installmentNumber])
  @@index([offlineLoanId])
  @@index([dueDate])
  @@index([paymentStatus])
  @@index([collectedById])
  @@index([offlineLoanId, paymentStatus]) // compound: find PENDING EMIs for a loan fast
  @@index([dueDate, paymentStatus]) // compound: overdue EMI reports
}

// EMI Reminder Log - Track all reminders sent
model EMIReminderLog {
  id               String    @id @default(cuid())
  // EMI reference (can be online or offline)
  emiScheduleId    String? // For online loans
  offlineLoanEMIId String? // For offline loans
  // Recipient info
  userId           String // Who received the reminder
  userRole         String // Role of the recipient
  // Reminder details
  reminderType     String // EMI_DUE_TODAY, EMI_DUE_TOMORROW, EMI_OVERDUE, etc.
  loanId           String // Loan reference
  loanNumber       String // Loan number for display
  customerName     String // Customer name
  emiAmount        Float // EMI amount
  dueDate          DateTime // EMI due date
  // Status
  sentAt           DateTime  @default(now())
  sentVia          String // IN_APP, SMS, EMAIL
  isRead           Boolean   @default(false)
  readAt           DateTime?
  // Timestamps
  createdAt        DateTime  @default(now())
  // Relations
  user             User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([emiScheduleId])
  @@index([offlineLoanEMIId])
  @@index([sentAt])
  @@index([reminderType])
}

// Offline Loan Status Enum
enum OfflineLoanStatus {
  PENDING_APPROVAL // Initial state for Interest Only Loan
  INTEREST_ONLY // Loan in interest-only phase
  ACTIVE // Normal EMI payments started
  CLOSED
  DEFAULTED
  RESTRUCTURED
}

// Secure Document Upload - For Interest Only Loan staff visit
model SecureDocument {
  id                String    @id @default(cuid())
  loanApplicationId String // Reference to loan application
  documentType      String // SECURE_DOCUMENT, COLLATERAL, etc.
  documentUrl       String // URL to the uploaded document
  documentName      String? // Original file name
  documentSize      Int? // File size in bytes
  mimeType          String? // File MIME type
  remarks           String? // Customer remarks
  uploadedById      String? // Who uploaded (customer or staff)
  uploadedByRole    String? // Role of uploader
  verified          Boolean   @default(false)
  verifiedById      String?
  verifiedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([loanApplicationId])
  @@index([documentType])
}

// Interest Payment History - Track all interest payments during interest-only phase
model InterestPaymentHistory {
  id                String   @id @default(cuid())
  loanApplicationId String // Reference to loan application
  offlineLoanId     String? // Reference to offline loan if applicable
  amount            Float // Interest amount paid
  paymentMode       String? // CASH, UPI, BANK_TRANSFER, etc.
  paymentDate       DateTime @default(now())
  collectedById     String? // Who collected the payment
  collectedByName   String? // Name of collector
  remarks           String?
  receiptNumber     String? // Receipt number if generated
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([loanApplicationId])
  @@index([offlineLoanId])
  @@index([paymentDate])
  @@index([collectedById])
}

// Action Log - For undo/redo functionality
model ActionLog {
  id           String    @id @default(cuid())
  // Who performed the action
  userId       String
  userRole     String
  // Action details
  actionType   String // CREATE, UPDATE, DELETE, PAYMENT, etc.
  module       String // OFFLINE_LOAN, EMI_PAYMENT, SETTLEMENT, etc.
  recordId     String // ID of the affected record
  recordType   String // OfflineLoan, OfflineLoanEMI, Payment, etc.
  // Data snapshots
  previousData String? // JSON string of data before action
  newData      String? // JSON string of data after action
  // Undo tracking
  canUndo      Boolean   @default(true)
  isUndone     Boolean   @default(false)
  undoneAt     DateTime?
  undoneById   String?
  // Redo tracking
  canRedo      Boolean   @default(false)
  isRedone     Boolean   @default(false)
  redoneAt     DateTime?
  redoneById   String?
  // Metadata
  description  String
  ipAddress    String?
  userAgent    String?
  // Timestamps
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  // Relations
  user         User      @relation(fields: [userId], references: [id])
  undoneBy     User?     @relation("ActionUndoBy", fields: [undoneById], references: [id])
  redoneBy     User?     @relation("ActionRedoBy", fields: [redoneById], references: [id])

  @@index([userId])
  @@index([actionType])
  @@index([module])
  @@index([recordId])
}

// ==================== FIXED ASSETS MANAGEMENT ====================

// Fixed Asset - Track company's fixed assets with depreciation
model FixedAsset {
  id        String @id @default(cuid())
  companyId String @default("default")

  // Asset Identification
  assetCode     String // Unique asset code (e.g., FA-001)
  assetName     String // Name of the asset
  assetCategory AssetCategory // Category of the asset

  // Asset Details
  description  String? // Detailed description
  serialNumber String? // Serial number for equipment
  location     String? // Physical location of asset
  department   String? // Department using the asset

  // Financial Details
  purchaseDate     DateTime // Date of purchase
  purchaseCost     Float // Original purchase cost
  additionalCosts  Float    @default(0) // Installation, transport, etc.
  totalCost        Float // purchaseCost + additionalCosts
  salvageValue     Float    @default(0) // Expected salvage/residual value
  usefulLifeYears  Int // Estimated useful life in years
  usefulLifeMonths Int // Useful life in months

  // Depreciation Details
  depreciationMethod      DepreciationMethod @default(STRAIGHT_LINE)
  depreciationRate        Float              @default(0) // Annual depreciation rate (%)
  accumulatedDepreciation Float              @default(0) // Total depreciation till date
  currentBookValue        Float              @default(0) // Current book value after depreciation
  lastDepreciationDate    DateTime? // Last depreciation calculated date

  // Status & Lifecycle
  status          AssetStatus @default(ACTIVE)
  acquisitionDate DateTime? // Date when asset was acquired
  disposalDate    DateTime? // Date when asset was disposed
  disposalValue   Float? // Value received on disposal
  disposalReason  String? // Reason for disposal

  // Insurance & Warranty
  insuranceProvider   String?
  insurancePolicyNo   String?
  insuranceExpiryDate DateTime?
  warrantyProvider    String?
  warrantyExpiryDate  DateTime?

  // Maintenance
  lastMaintenanceDate DateTime?
  nextMaintenanceDate DateTime?
  maintenanceNotes    String?

  // Documentation
  invoiceNumber String?
  invoiceDate   DateTime?
  invoiceUrl    String? // URL to invoice document
  imageUrl      String? // Photo of the asset

  // Audit Trail
  createdById  String
  approvedById String?
  approvedAt   DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  company          Company?               @relation(fields: [companyId], references: [id])
  depreciationLogs AssetDepreciationLog[]

  @@unique([companyId, assetCode])
  @@index([companyId])
  @@index([assetCode])
  @@index([assetCategory])
  @@index([status])
  @@index([purchaseDate])
}

// Asset Depreciation Log - Track monthly/yearly depreciation entries
model AssetDepreciationLog {
  id      String @id @default(cuid())
  assetId String

  // Depreciation Period
  depreciationDate DateTime // Date of depreciation calculation
  financialYear    String // e.g., "2024-25"
  period           String // e.g., "March 2024"

  // Amounts
  openingBookValue   Float // Book value at start of period
  depreciationAmount Float // Depreciation for this period
  closingBookValue   Float // Book value after depreciation

  // Journal Reference
  journalEntryId String? // Link to journal entry if created

  // Metadata
  calculatedAt   DateTime @default(now())
  calculatedById String

  // Relation
  asset FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([depreciationDate])
  @@index([financialYear])
}

// Asset Category Enum
enum AssetCategory {
  FURNITURE_FIXTURES // Tables, chairs, cabinets
  OFFICE_EQUIPMENT // Computers, printers, scanners
  VEHICLES // Cars, bikes, trucks
  MACHINERY_PLANT // Manufacturing equipment
  BUILDINGS // Office buildings, warehouses
  LAND // Land assets
  ELECTRONICS // Laptops, phones, tablets
  ELECTRICAL_INSTALLATIONS // ACs, generators, electrical fittings
  INTANGIBLE_ASSETS // Software licenses, patents
  OTHER // Any other fixed assets
}

// Depreciation Method Enum
enum DepreciationMethod {
  STRAIGHT_LINE // Equal depreciation each year
  DIMINISHING_BALANCE // Reducing balance method
  WRITTEN_DOWN_VALUE // WDV method (common in India)
  UNITS_OF_PRODUCTION // Based on usage
}

// Asset Status Enum
enum AssetStatus {
  ACTIVE // Currently in use
  UNDER_MAINTENANCE // Being repaired/maintained
  DISPOSED // Sold or scrapped
  WRITTEN_OFF // Fully depreciated or lost
  SOLD // Sold to another party
  IDLE // Not in use but not disposed
}

// ==================== PAYMENT REQUEST SYSTEM ====================

// Payment Request - Customer initiated payment requests
model PaymentRequest {
  id            String @id @default(cuid())
  requestNumber String @unique

  // Loan & EMI Details
  loanApplicationId String
  emiScheduleId     String?
  customerId        String

  // Payment Details
  paymentType     PaymentType @default(FULL_EMI)
  requestedAmount Float

  // For Partial Payment
  partialAmount        Float? // Amount being paid now
  remainingAmount      Float? // Remaining amount to pay later
  newDueDate           DateTime? // New due date for remaining amount
  partialPaymentNumber Int?      @default(0) // 1st or 2nd partial payment

  // For Interest Only Payment
  interestAmount    Float? // Interest amount being paid
  principalDeferred Boolean @default(false)

  // Payment Method Details
  paymentMethod String? // UPI, BANK_TRANSFER, CASH
  utrNumber     String?
  proofUrl      String? // Screenshot proof
  proofFileName String?

  // QR/UPI Payment Details
  upiId              String?
  qrCodeUrl          String?
  bankAccountDetails String? // JSON string with bank details

  // Status & Approval
  status PaymentRequestStatus @default(PENDING)

  // Approval Details
  reviewedById    String?
  reviewedAt      DateTime?
  reviewRemarks   String?
  rejectionReason String?

  // Payment Confirmation
  paymentConfirmedAt DateTime?
  transactionRef     String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  loanApplication LoanApplication @relation(fields: [loanApplicationId], references: [id])
  emiSchedule     EMISchedule?    @relation(fields: [emiScheduleId], references: [id])
  customer        User            @relation(fields: [customerId], references: [id])
  reviewer        User?           @relation("PaymentRequestReviewer", fields: [reviewedById], references: [id])

  @@index([loanApplicationId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

enum PaymentRequestStatus {
  PENDING // Waiting for cashier review
  UNDER_REVIEW // Being reviewed by cashier
  APPROVED // Approved by cashier, EMI marked paid
  REJECTED // Rejected by cashier
  EXPIRED // Request expired (e.g., time limit passed)
  CANCELLED // Cancelled by customer
}

// Payment Option Settings - Role-based settings for payment options
model PaymentOptionSettings {
  id String @id @default(cuid())

  // Scope - can be global, company-specific, or loan-specific
  scope             String  @default("GLOBAL") // GLOBAL, COMPANY, LOAN
  companyId         String?
  loanApplicationId String?

  // Payment Options Enabled
  enableFullPayment    Boolean @default(true)
  enablePartialPayment Boolean @default(true)
  enableInterestOnly   Boolean @default(true)

  // Partial Payment Settings
  maxPartialPayments Int   @default(2) // Max 2 partial payments per EMI
  partialPaymentFee  Float @default(0)

  // Interest Only Settings
  maxInterestOnlyPerLoan Int   @default(3) // Max 3 interest-only payments per loan
  interestOnlyFee        Float @default(0)

  // Payment Method Settings
  acceptedPaymentMethods String @default("UPI,BANK_TRANSFER,CASH")

  // UPI/QR Settings
  defaultUpiId       String?
  defaultQrCodeUrl   String?
  defaultBankDetails String? // JSON string with bank details

  // Created/Updated by
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scope])
  @@index([companyId])
  @@index([loanApplicationId])
}

// Company Payment Settings - Company-specific payment configurations
model CompanyPaymentSettings {
  id        String @id @default(cuid())
  companyId String @unique

  // Payment Options
  enableFullPayment    Boolean @default(true)
  enablePartialPayment Boolean @default(true)
  enableInterestOnly   Boolean @default(true)

  // Partial Payment Rules
  maxPartialPaymentsPerEMI Int     @default(2)
  partialPaymentFeePercent Float   @default(0)
  allowDateChangeOnPartial Boolean @default(true)

  // Interest Only Rules
  maxInterestOnlyPayments Int     @default(3)
  interestOnlyFeePercent  Float   @default(0)
  addNewEMIOnInterestOnly Boolean @default(true) // Add new EMI with principal + interest

  // Payment Methods
  acceptedMethods String @default("UPI,BANK_TRANSFER,CASH")

  // UPI Configuration
  companyUpiId     String?
  companyQrCodeUrl String?

  // Bank Account for Collections
  collectionBankAccountId String?

  // Created/Updated
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id])
}

// Company Default Payment Page - Auto-created when company's bank account is added
// This is the PRIMARY payment page for EMI collections
model CompanyPaymentPage {
  id        String @id @default(cuid())
  companyId String @unique // One payment page per company

  // Payment Display Details (what customer sees)
  upiId     String? // UPI ID for receiving payments
  qrCodeUrl String? @db.Text // QR Code image (base64 data URL or file URL)

  // Bank Details (from company's bank account)
  bankAccountId String? @unique // Linked bank account
  bankName      String? // Bank name shown to customer
  accountNumber String? // Account number shown to customer
  accountName   String? // Account holder name shown to customer
  ifscCode      String? // IFSC code shown to customer

  // Role assignment for secondary payments (extra EMIs)
  // When extra EMIs are paid through this page, this role's personal credit increases
  secondaryPaymentRoleId String? // Role who gets credit for secondary payments

  // Status
  isActive Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  company              Company? @relation(fields: [companyId], references: [id])
  secondaryPaymentRole User?    @relation("SecondaryPaymentRole", fields: [secondaryPaymentRoleId], references: [id])

  @@index([companyId])
  @@index([isActive])
  @@index([bankAccountId])
}

// Secondary Payment Pages (Display Only - Created by Cashier)
// These are for showing different payment details to customers
// BUT actual transactions happen in Company's Default Bank Account
// Common for all companies - no company selection needed
model SecondaryPaymentPage {
  id          String  @id @default(cuid())
  companyId   String? // Optional - common for all companies if null
  name        String // Name for this payment page (e.g., "Partner Collection Point 1")
  description String? // Description

  // Payment Display Details (what customer sees)
  upiId         String? // UPI ID shown to customer
  qrCodeUrl     String? @db.Text // QR Code image shown to customer
  bankName      String? // Bank name shown to customer
  accountNumber String? // Account number shown to customer
  accountName   String? // Account holder name shown to customer
  ifscCode      String? // IFSC code shown to customer

  // Role Selection - When payment done via this page, this role's personal credit increases
  roleId   String? // User/Role who owns this payment page
  roleType String? // Role type (CASHIER, STAFF, AGENT, etc.)

  isActive    Boolean  @default(true)
  createdById String // Who created this payment page (usually Cashier)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company            Company?            @relation(fields: [companyId], references: [id])
  creator            User?               @relation(fields: [createdById], references: [id])
  role               User?               @relation("PaymentPageRole", fields: [roleId], references: [id])
  emiPaymentSettings EMIPaymentSetting[]
  offlineLoans       OfflineLoan[]       @relation("OfflineLoanSecondaryPage")

  @@index([companyId])
  @@index([isActive])
  @@index([roleId])
}

// Mirror Loan Mapping - Tracks mirror loans between companies
model MirrorLoanMapping {
  id                String  @id @default(cuid())
  originalLoanId    String // Original loan ID (stays with Company 3)
  mirrorLoanId      String? // Mirror loan ID (the separate loan created in Company 1/C2) - NULL for offline loans
  originalCompanyId String // Company 3 - the company that owns the loan (receives extra EMI profit)
  mirrorCompanyId   String // Company 1 - the operational company (receives mirror interest)

  // Mirror Type
  mirrorType String // COMPANY_1_15_PERCENT or COMPANY_2_SAME_RATE

  // Offline Loan Support
  isOfflineLoan    Boolean @default(false) // TRUE if this mapping is for an offline loan
  mirrorLoanNumber String? // Generated mirror loan number (for offline loans, stored here instead of creating separate loan)

  // Display Color - Unique color for this mirror pair (both loans show same color)
  displayColor String? // Hex color code like "#FF5733"

  // Interest Configuration
  originalInterestRate Float // e.g., 24%
  originalInterestType String @default("FLAT")
  mirrorInterestRate   Float // e.g., 15%
  mirrorInterestType   String @default("REDUCING")

  // EMI Details
  originalEMIAmount Float // EMI customer pays
  originalTenure    Int // Total EMIs customer sees (e.g., 10)
  mirrorTenure      Int // EMIs for mirror loan (e.g., 9) - calculated with reducing
  extraEMICount     Int   @default(0) // originalTenure - mirrorTenure = extra EMIs
  leftoverAmount    Float @default(0) // Small leftover amount if any

  // Disbursement Configuration - Money disbursed from mirror company (Company 1)
  disbursementCompanyId     String? // Which company's bank account to use for disbursement (mirror company = Company 1)
  disbursementBankAccountId String? // Bank account used for disbursement

  // Mirror Progress Tracking
  mirrorEMIsPaid    Int       @default(0) // How many mirror EMIs have been paid
  extraEMIsPaid     Int       @default(0) // How many extra EMIs have been paid
  mirrorCompletedAt DateTime? // When mirror loan finished

  // Profit Tracking (for Company 3)
  totalMirrorInterest   Float   @default(0) // Interest that goes to Company 1
  totalExtraEMIProfit   Float   @default(0) // Profit from extra EMIs for Company 3
  totalProfitReceived   Float   @default(0) // Actual profit received so far
  mirrorProcessingFee   Float   @default(0) // Auto-calc: originalEMI - lastMirrorEMI. Income on EMI#1 payment.
  processingFeeRecorded Boolean @default(false) // Set to true once booked as income

  // Sync Settings
  mirrorSyncEnabled Boolean @default(true)

  // Payment Page for Extra EMIs
  extraEMIPaymentPageId String? // Secondary payment page for extra EMI payments

  // Tracking
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  // NOTE: For offline loans (isOfflineLoan=true), the IDs refer to OfflineLoan table
  // For online loans (isOfflineLoan=false), the IDs refer to LoanApplication table
  // We don't use foreign key constraints here to support both tables
  mirrorCompany   Company @relation(fields: [mirrorCompanyId], references: [id])
  originalCompany Company @relation("OriginalCompany", fields: [originalCompanyId], references: [id])

  @@unique([originalLoanId, mirrorCompanyId])
  @@index([originalLoanId])
  @@index([mirrorLoanId])
  @@index([mirrorCompanyId])
  @@index([originalCompanyId])
  @@index([disbursementCompanyId])
}

// Pending Mirror Loan Request - Created during Final Approval, needs approval before disbursement
model PendingMirrorLoan {
  id                String @id @default(cuid())
  originalLoanId    String // Original loan ID (stays with Company 3)
  originalCompanyId String // Company 3 - the company that owns the customer relationship
  mirrorCompanyId   String // Company 1 or Company 2 - the mirror loan provider

  // Mirror Type
  mirrorType String // COMPANY_1_15_PERCENT or COMPANY_2_SAME_RATE

  // Offline Loan Support
  isOfflineLoan Boolean @default(false) // TRUE if this mapping is for an offline loan

  // Interest Configuration
  originalInterestRate Float // e.g., 24%
  originalInterestType String @default("FLAT")
  mirrorInterestRate   Float // e.g., 15% or 24%
  mirrorInterestType   String @default("REDUCING")

  // EMI Details
  originalEMIAmount Float // EMI customer pays
  originalTenure    Int // Total EMIs customer sees
  mirrorTenure      Int // EMIs for mirror loan (calculated)
  extraEMICount     Int   @default(0) // originalTenure - mirrorTenure
  leftoverAmount    Float @default(0)

  // Principal Amount
  principalAmount Float // The approved loan amount

  // Status: PENDING → APPROVED → DISBURSED → REJECTED
  status String @default("PENDING") // PENDING, APPROVED, DISBURSED, REJECTED

  // Approval tracking
  approvedById String? // Super Admin who approved
  approvedAt   DateTime?

  // Disbursement tracking
  disbursedById             String? // Cashier who disbursed
  disbursedAt               DateTime?
  disbursementBankAccountId String?
  disbursementReference     String?

  // Rejection tracking
  rejectedById    String?
  rejectedAt      DateTime?
  rejectionReason String?

  // Created by
  createdBy String // User who created the request
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations - Note: For offline loans (isOfflineLoan=true), originalLoanId refers to OfflineLoan table
  // We don't use foreign key constraints here to support both tables
  mirrorCompany   Company @relation(fields: [mirrorCompanyId], references: [id])
  originalCompany Company @relation("PendingMirrorOriginalCompany", fields: [originalCompanyId], references: [id])

  @@unique([originalLoanId, mirrorCompanyId])
  @@index([originalLoanId])
  @@index([mirrorCompanyId])
  @@index([originalCompanyId])
  @@index([status])
  @@index([createdBy])
}

// EMI Payment Settings - Per EMI toggle options
model EMIPaymentSetting {
  id                String @id @default(cuid())
  emiScheduleId     String @unique
  loanApplicationId String

  // Payment Options Toggle (defaults: Full=ON, others=OFF)
  enableFullPayment    Boolean @default(true)
  enablePartialPayment Boolean @default(false)
  enableInterestOnly   Boolean @default(false)
  enablePrincipalOnly  Boolean @default(false)

  // Payment Page Selection (kept for backward compat — UI now simplified)
  useDefaultCompanyPage  Boolean @default(true)
  secondaryPaymentPageId String?

  // Tracking
  lastModifiedById String?
  lastModifiedAt   DateTime? @updatedAt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emiSchedule          EMISchedule?          @relation(fields: [emiScheduleId], references: [id])
  loanApplication      LoanApplication?      @relation(fields: [loanApplicationId], references: [id])
  secondaryPaymentPage SecondaryPaymentPage? @relation(fields: [secondaryPaymentPageId], references: [id])
  modifiedBy           User?                 @relation(fields: [lastModifiedById], references: [id])

  @@index([emiScheduleId])
  @@index([loanApplicationId])
}


// ==================== SUPPORT & TICKET SYSTEM ====================

// Support Ticket
model SupportTicket {
  id           String  @id @default(cuid())
  ticketNumber String  @unique // TK-2024-0001
  customerId   String
  assignedToId String? // Admin/Staff assigned

  // Ticket Details
  subject     String
  description String
  category    String @default("GENERAL") // GENERAL, PAYMENT, LOAN, TECHNICAL, OTHER
  priority    String @default("NORMAL") // LOW, NORMAL, HIGH, CRITICAL
  status      String @default("OPEN") // OPEN, IN_PROGRESS, WAITING_CUSTOMER, RESOLVED, CLOSED

  // Source
  source           String  @default("APP") // APP, CHATBOT, EMAIL, PHONE
  chatbotSessionId String? // Reference to chatbot session if created from AI chat

  // Tracking
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?

  // Satisfaction
  rating   Int? // 1-5 stars
  feedback String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  customer   User             @relation("CustomerTickets", fields: [customerId], references: [id])
  assignedTo User?            @relation("AssignedTickets", fields: [assignedToId], references: [id])
  messages   TicketMessage[]
  activities TicketActivity[]

  @@index([ticketNumber])
  @@index([customerId])
  @@index([assignedToId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
}

// Ticket Messages
model TicketMessage {
  id          String    @id @default(cuid())
  ticketId    String
  senderId    String
  senderType  String // CUSTOMER, ADMIN, SYSTEM, CHATBOT
  message     String
  attachments String? // JSON array of attachment URLs
  isInternal  Boolean   @default(false) // Internal notes not visible to customer
  isRead      Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([senderId])
  @@index([createdAt])
}

// Ticket Activity Log
model TicketActivity {
  id          String   @id @default(cuid())
  ticketId    String
  action      String // CREATED, ASSIGNED, STATUS_CHANGED, PRIORITY_CHANGED, REPLIED, CLOSED
  description String
  performedBy String?
  metadata    String? // JSON for additional data
  createdAt   DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([action])
  @@index([createdAt])
}

// ==================== CHAT & CHATBOT SYSTEM ====================

// Chatbot Conversation Session
model ChatbotSession {
  id                 String  @id @default(cuid())
  customerId         String
  status             String  @default("ACTIVE") // ACTIVE, ESCALATED, CLOSED
  escalationTicketId String? // If escalated, link to ticket

  // Context
  contextData  String? // JSON - last discussed topic, loan id, etc.
  messageCount Int     @default(0)

  // AI Context
  conversationHistory String? // JSON array of conversation for context

  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  lastMessageAt DateTime  @default(now())

  customer User             @relation(fields: [customerId], references: [id])
  messages ChatbotMessage[]

  @@index([customerId])
  @@index([status])
  @@index([startedAt])
}

// Chatbot Messages
model ChatbotMessage {
  id         String  @id @default(cuid())
  sessionId  String
  senderType String // CUSTOMER, CHATBOT, ADMIN
  message    String
  intent     String? // Detected intent: PAYMENT_STATUS, LOAN_STATUS, EMI_QUERY, etc.
  entities   String? // JSON - extracted entities (loan id, amount, etc.)

  // AI Response Metadata
  confidence       Float?
  needsEscalation  Boolean @default(false)
  escalationReason String?

  // Response Actions
  suggestedActions String? // JSON array of quick actions/buttons

  createdAt DateTime @default(now())

  session ChatbotSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([senderType])
  @@index([createdAt])
}

// Live Chat Session (for admin chat)
model LiveChatSession {
  id         String  @id @default(cuid())
  customerId String
  adminId    String?
  status     String  @default("WAITING") // WAITING, ACTIVE, CLOSED

  startedAt     DateTime  @default(now())
  acceptedAt    DateTime?
  endedAt       DateTime?
  lastMessageAt DateTime  @default(now())

  customer User              @relation("CustomerLiveChats", fields: [customerId], references: [id])
  admin    User?             @relation("AdminLiveChats", fields: [adminId], references: [id])
  messages LiveChatMessage[]

  @@index([customerId])
  @@index([adminId])
  @@index([status])
}

// Live Chat Messages
model LiveChatMessage {
  id          String    @id @default(cuid())
  sessionId   String
  senderId    String
  senderType  String // CUSTOMER, ADMIN
  message     String
  attachments String? // JSON array of attachment URLs
  isRead      Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  session LiveChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender  User            @relation("LiveChatSender", fields: [senderId], references: [id])

  @@index([sessionId])
  @@index([senderId])
  @@index([createdAt])
}

// ==================== USER SESSION & SECURITY ====================

// User Session for Auto-Logout and Session Management
model UserSession {
  id           String  @id @default(cuid())
  userId       String
  sessionToken String  @unique
  deviceInfo   String? // JSON - browser, OS, device type
  ipAddress    String?
  location     String? // City, Country from IP
  userAgent    String?

  // Activity Tracking
  lastActivityAt DateTime  @default(now())
  loginAt        DateTime  @default(now())
  logoutAt       DateTime?

  // Status
  isActive     Boolean @default(true)
  logoutReason String? // MANUAL, AUTO_LOGOUT, FORCE_LOGOUT, SESSION_EXPIRED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sessionToken])
  @@index([isActive])
  @@index([lastActivityAt])
}

// User Preferences for Theme and Settings
model UserPreference {
  id     String @id @default(cuid())
  userId String @unique

  // Theme Settings
  theme        String @default("SYSTEM") // LIGHT, DARK, SYSTEM
  primaryColor String @default("emerald")

  // Auto-Logout Settings
  autoLogoutMinutes    Int     @default(15) // Minutes of inactivity before auto-logout
  showLogoutWarning    Boolean @default(true)
  logoutWarningMinutes Int     @default(2) // Minutes before logout to show warning

  // Notification Preferences
  enableNotifications Boolean @default(true)
  enableSoundAlerts   Boolean @default(true)

  // Language
  language String @default("en")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ==================== CONTACT ENQUIRY ====================

// Contact Enquiry from Landing Page
model ContactEnquiry {
  id          String    @id @default(cuid())
  name        String
  email       String
  phone       String
  message     String
  status      String    @default("PENDING") // PENDING, CONTACTED, RESOLVED, CLOSED
  notes       String? // Internal notes
  contactedAt DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ==================== WORKFLOW VALIDATOR (AI BOT) ====================

// Validation Rule - Defines what to check in the system
model ValidationRule {
  id          String @id @default(cuid())
  code        String @unique // e.g., "MIRROR_MAPPING_001"
  name        String // e.g., "Mirror Loan Mapping Check"
  description String // What this rule checks
  category    String // MIRROR_LOAN, ACCOUNTING, EMI, BALANCE, DATA_INTEGRITY
  severity    String @default("MEDIUM") // CRITICAL, HIGH, MEDIUM, LOW

  // Rule Configuration
  isActive         Boolean @default(true)
  autoFixable      Boolean @default(false) // Can this be auto-fixed?
  requiresApproval Boolean @default(true) // Does fix need SuperAdmin approval?

  // Detection Logic (stored as JSON for flexibility)
  detectionLogic String // JSON: conditions to check

  // Fix Logic (stored as JSON)
  fixLogic String? // JSON: steps to fix the issue

  // Impact and Guidance
  impactDescription String? // What happens if this issue is not fixed
  fixGuidance       String? // Step-by-step guide for manual fix

  // Statistics
  timesDetected  Int       @default(0)
  timesFixed     Int       @default(0)
  lastDetectedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issues ValidationIssue[]

  @@index([category])
  @@index([isActive])
  @@index([severity])
}

// Validation Issue - Detected problem in the system
model ValidationIssue {
  id     String         @id @default(cuid())
  ruleId String
  rule   ValidationRule @relation(fields: [ruleId], references: [id])

  // What is affected
  entityType       String // OFFLINE_LOAN, LOAN_APPLICATION, EMI, JOURNAL_ENTRY, MIRROR_MAPPING, etc.
  entityId         String // ID of the affected record
  entityIdentifier String? // Human-readable identifier (loan number, etc.)

  // Issue details
  title       String // Short description
  description String // Full explanation
  severity    String // CRITICAL, HIGH, MEDIUM, LOW (can override rule severity)

  // Current state vs Expected state
  currentState       String // JSON: What it currently looks like
  expectedState      String // JSON: What it should look like
  differenceAnalysis String? // JSON: Analysis of what's different

  // Fix suggestion
  suggestedFix   String // JSON: Steps to fix it
  fixDescription String // Human-readable fix description
  fixSqlPreview  String? // SQL preview for database fixes

  // Related entities (for context)
  relatedEntities String? // JSON: [{type, id, relation}]

  // Status
  status String @default("PENDING") // PENDING, IN_PROGRESS, APPROVED, REJECTED, FIXED, IGNORED, CANT_FIX

  // Review tracking
  reviewedById   String? // User ID who reviewed
  reviewedByName String? // Name of reviewer
  reviewedAt     DateTime?
  reviewNotes    String? // Notes from reviewer

  // Fix tracking
  fixedById   String? // User ID who applied fix
  fixedByName String? // Name of fixer
  fixedAt     DateTime?
  fixResult   String? // JSON: Result of fix attempt

  // Snooze/Defer
  snoozedUntil DateTime?
  snoozedById  String?
  snoozeReason String?

  // Recurrence tracking
  recurrenceCount Int     @default(0)
  parentIssueId   String? // If this is a recurrence of a previous issue

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fixLogs ValidationFixLog[]

  @@index([status])
  @@index([entityType, entityId])
  @@index([severity])
  @@index([createdAt])
  @@index([ruleId])
}

// Validation Fix Log - History of fixes applied
model ValidationFixLog {
  id      String          @id @default(cuid())
  issueId String
  issue   ValidationIssue @relation(fields: [issueId], references: [id])

  // Fix details
  fixType    String // AUTO, MANUAL, SUGGESTED
  fixApplied String // JSON: What was changed

  // Who applied
  appliedById   String? // User ID or "SYSTEM_AUTO"
  appliedByName String? // Name or "System"

  // Result
  result          String // SUCCESS, FAILED, PARTIAL
  errorMessage    String?
  affectedRecords Int     @default(0)

  // Before/After state for rollback
  beforeState String? // JSON: State before fix
  afterState  String? // JSON: State after fix

  // Duration
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  durationMs  Int? // How long the fix took

  createdAt DateTime @default(now())

  @@index([issueId])
  @@index([result])
  @@index([createdAt])
}

// Validator Settings - System-wide configuration
model ValidatorSettings {
  id String @id @unique @default(cuid())

  // Master switch
  isEnabled Boolean @default(true)

  // Schedule configuration
  scheduleType String    @default("HOURLY") // MANUAL, HOURLY, DAILY, WEEKLY, CUSTOM
  customCron   String? // Custom cron expression if scheduleType is CUSTOM
  lastRunAt    DateTime?
  nextRunAt    DateTime?
  isRunning    Boolean   @default(false)

  // Run configuration
  maxIssuesPerRun Int @default(100) // Max issues to detect per run
  timeoutMinutes  Int @default(30) // Max time for a scan

  // Notification settings
  notifyOnIssues   Boolean @default(true)
  notifyOnCritical Boolean @default(true)
  notifyOnFixes    Boolean @default(true)
  notifyEmails     String? // JSON array of email addresses

  // Auto-fix settings
  autoFixEnabled          Boolean @default(false)
  autoFixSeverities       String? // JSON array: ["LOW", "MEDIUM"]
  autoFixRequiresApproval Boolean @default(true)

  // Rule management
  disabledRules String? // JSON array of rule IDs to skip

  // Performance
  parallelRules Boolean @default(false) // Run rules in parallel
  batchSize     Int     @default(50) // Records per batch

  // Audit
  totalRuns        Int @default(0)
  totalIssuesFound Int @default(0)
  totalIssuesFixed Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Validator Run History - Track each scan
model ValidatorRun {
  id String @id @default(cuid())

  // Run info
  runType         String // SCHEDULED, MANUAL, TRIGGERED
  triggeredBy     String? // User ID or "SYSTEM"
  triggeredByName String? // Name

  // Timing
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  durationMs  Int?
  status      String    @default("RUNNING") // RUNNING, COMPLETED, FAILED, CANCELLED

  // Results
  rulesRun         Int     @default(0)
  recordsScanned   Int     @default(0)
  issuesFound      Int     @default(0)
  issuesByCategory String? // JSON: {MIRROR_LOAN: 5, ACCOUNTING: 3}
  issuesBySeverity String? // JSON: {CRITICAL: 1, HIGH: 3, MEDIUM: 5}

  // Errors
  errorMessage String?
  errorStack   String?

  // Performance
  peakMemoryMb  Float?
  avgRuleTimeMs Float?

  createdAt DateTime @default(now())

  @@index([status])
  @@index([startedAt])
  @@index([runType])
}

// ============================================================
// SYSTEM SETTINGS — Global config managed by Super Admin
// ============================================================
model SystemSettings {
  id                        String   @id @default(cuid())
  // Penalty Configuration
  penaltyPerDay             Float    @default(100) // ₹ penalty added per day after due date
  penaltyGraceDays          Int      @default(0) // Grace days before penalty starts (0 = immediate)
  penaltyMaxAmount          Float? // Max penalty cap (null = no cap)
  // Loan Color Config (days before due)
  colorGreenDays            Int      @default(2) // Blink green X days before due
  colorYellowDays           Int      @default(1) // Blink yellow X day before due
  colorRedDaysOverdue       Int      @default(0) // Red when overdue (0 = same day)
  // Role Mirror Loan Visibility
  agentCanSeeMirror         Boolean  @default(false)
  staffCanSeeMirror         Boolean  @default(false)
  companyCanSeeMirror       Boolean  @default(false)
  accountantCanSeeMirror    Boolean  @default(false)
  // Notification triggers
  sendEMIReminderDaysBefore Int      @default(3) // Days before EMI to send reminder
  sendEMISameDayReminder    Boolean  @default(true)
  sendPenaltyNotify         Boolean  @default(true) // Notify customer when penalty added
  penaltyNotifyIntervalHrs  Int      @default(24) // How often to re-notify (hours)
  // Processing fee config
  onlineProcessingFeeMode   String   @default("AT_DISBURSEMENT") // AT_DISBURSEMENT | AT_EMI1
  offlineProcessingFeeMode  String   @default("AT_CREATION") // AT_CREATION | MANUAL
  // Notification scenario toggles (JSON: {emi_due_3days: true, ...})
  notificationScenarios     String?  // JSON: Record<string, boolean> for each scenario key
  // Theme color (hex color code for app primary color)
  themeColor                String   @default("#4F46E5")
  // Meta
  updatedById               String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@map("system_settings")
}

// ============================================================
// ENQUIRY — Contact Us form submissions → Cashier / SA
// ============================================================
model Enquiry {
  id            String    @id @default(cuid())
  name          String
  email         String
  phone         String?
  subject       String
  message       String    @db.Text
  status        String    @default("PENDING") // PENDING | SEEN | RESOLVED
  seenByCashier Boolean   @default(false)
  seenBySA      Boolean   @default(false)
  resolvedBy    String?
  resolvedAt    DateTime?
  resolvedNote  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ============================================================
// MESSAGE — Inter-role messaging system
// ============================================================
model Message {
  id            String    @id @default(cuid())
  fromUserId    String
  toUserId      String? // null = broadcast / announcement
  toRole        String? // AGENT, STAFF, CASHIER, CUSTOMER, ALL
  subject       String?
  body          String    @db.Text
  isRead        Boolean   @default(false)
  readAt        DateTime?
  loanId        String? // Optional: linked loan context
  offlineLoanId String? // Optional: linked offline loan context
  attachmentUrl String?
  parentId      String? // For threaded replies
  createdAt     DateTime  @default(now())
  fromUser      User      @relation("MessagesSent", fields: [fromUserId], references: [id])
  toUser        User?     @relation("MessagesReceived", fields: [toUserId], references: [id])
  parent        Message?  @relation("MessageThread", fields: [parentId], references: [id])
  replies       Message[] @relation("MessageThread")

  @@index([fromUserId])
  @@index([toUserId])
  @@index([toRole])
  @@index([createdAt])
  @@index([isRead])
}

// Receipt Template — stores receipt format (fields JSON) for EMI and Loan receipts
model ReceiptTemplate {
  id          String   @id @default(cuid())
  type        String   // 'EMI' | 'LOAN'
  name        String
  companyName String   @default("MoneyMitra Finance")
  bgColor     String   @default("#ffffff")
  accentColor String   @default("#4F46E5")
  fields      String   // JSON: ReceiptField[]
  createdById String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([type])
  @@map("receipt_templates")
}